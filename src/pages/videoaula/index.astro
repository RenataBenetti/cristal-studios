---
// VERSÃO A — Ângulo: Autoridade
// Público: médicos, advogados, terapeutas
// Hipótese: profissional quer ser visto como referência no seu segmento
import LandingPage from '../../layouts/LandingPage.astro';

const WA_NUMBER = "5519974062004";
const WA_MSG = encodeURIComponent("Olá! Vim pela página de Videoaula e quero um orçamento para gravar meu curso.");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;

const WA_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---

<LandingPage
  title="Grave sua Videoaula com Qualidade Profissional: Cristal Studios Campinas"
  description="Estúdio completo para médicos, advogados e terapeutas gravarem videoaulas e cursos online. Gravação, edição e entrega pronta. Campinas/SP."
>

  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-container">
      <span class="lp-tag">Videoaula Profissional · Campinas/SP</span>
      <h1 class="lp-h1">
        Seu conhecimento vale muito.<br />
        <span class="highlight">A apresentação precisa dizer o mesmo.</span>
      </h1>
      <p class="lp-lead">
        Médicos, advogados e terapeutas que gravam em estúdio profissional vendem mais cursos, cobram mais caro e são vistos como referência no seu segmento, antes mesmo de o aluno assistir à primeira aula.
      </p>
      <a href={WA_LINK} target="_blank" rel="noopener" class="lp-btn lp-btn-hero">
        <Fragment set:html={WA_ICON} />
        Quero gravar meu curso profissionalmente
      </a>
      <p class="lp-badge">✓ Você só precisa aparecer. Cuidamos de tudo.</p>
    </div>
  </section>

  <!-- O QUE MUDA -->
  <section class="lp-section lp-section-dark">
    <div class="lp-container">
      <span class="lp-tag">A diferença que o aluno percebe</span>
      <h2 class="lp-h2">Qualidade de imagem e som <span class="highlight">não é detalhe.</span></h2>
      <div class="lp-comparativo">
        <div class="lp-comp-card lp-comp-antes">
          <div class="lp-comp-label">Sem estúdio</div>
          <ul>
            <li>❌ Fundo da casa ou consultório</li>
            <li>❌ Iluminação que cansa os olhos</li>
            <li>❌ Som com eco e ruído de fundo</li>
            <li>❌ Imagem pixelada ou escura</li>
            <li>❌ Edição amadora que distrai</li>
          </ul>
        </div>
        <div class="lp-comp-card lp-comp-depois">
          <div class="lp-comp-label lp-comp-label-amber">Com a Cristal Studios</div>
          <ul>
            <li>✓ Cenário profissional que transmite credibilidade</li>
            <li>✓ Iluminação de estúdio que valoriza você</li>
            <li>✓ Áudio cristalino, sem distrações</li>
            <li>✓ Imagem em alta definição</li>
            <li>✓ Edição completa entregue pronta</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="lp-section">
    <div class="lp-container">
      <span class="lp-tag">Como funciona</span>
      <h2 class="lp-h2">Você foca no <span class="highlight">conteúdo.</span> A gente faz o resto.</h2>
      <div class="lp-steps">
        <div class="lp-step">
          <span class="lp-step-num">1</span>
          <div>
            <strong>Você chega, a gente prepara</strong>
            <p>Nosso estúdio já está configurado: câmera, iluminação, microfone e cenário prontos para você gravar.</p>
          </div>
        </div>
        <div class="lp-step">
          <span class="lp-step-num">2</span>
          <div>
            <strong>Grave sem se preocupar com técnica</strong>
            <p>Nossa equipe cuida de tudo. Você só precisa falar o que sabe, que é o que realmente importa.</p>
          </div>
        </div>
        <div class="lp-step">
          <span class="lp-step-num">3</span>
          <div>
            <strong>Receba tudo editado e pronto</strong>
            <p>Edição profissional com cortes, trilha, vinheta, legendas e arte de abertura. Pronto para publicar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PARA QUEM É -->
  <section class="lp-section lp-section-dark">
    <div class="lp-container">
      <span class="lp-tag">Para quem é</span>
      <h2 class="lp-h2">Feito para quem <span class="highlight">vende conhecimento</span></h2>
      <div class="lp-grid-3">
        <div class="lp-card">
          <div class="lp-icon">🩺</div>
          <h3>Médicos</h3>
          <p>Cursos de saúde, palestras, conteúdo educativo para pacientes ou formação para colegas.</p>
        </div>
        <div class="lp-card">
          <div class="lp-icon">⚖️</div>
          <h3>Advogados</h3>
          <p>Cursos jurídicos, videoaulas para concursos, conteúdo de atualização profissional.</p>
        </div>
        <div class="lp-card">
          <div class="lp-icon">🧠</div>
          <h3>Terapeutas e Coaches</h3>
          <p>Programas online, mentorias gravadas, cursos de desenvolvimento pessoal e profissional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL COM FOTO -->
  <section class="lp-cta-final">
    <div class="lp-container lp-cta-final-grid">
      <div class="lp-cta-texto">
        <h2 class="lp-h2">
          Seus alunos precisam ver<br />
          <span class="highlight">um especialista de verdade.</span>
        </h2>
        <p>Fale com a Cristal Studios e receba um orçamento personalizado para o seu projeto.</p>
        <a href={WA_LINK} target="_blank" rel="noopener" class="lp-btn lp-btn-hero">
          <Fragment set:html={WA_ICON} />
          Solicitar orçamento
        </a>
        <p class="lp-cta-sub">Estúdio completo em Campinas/SP · Gravação e edição incluídas</p>
      </div>
      <div class="lp-cta-foto">
        <picture>
          <source srcset="/estudio.webp" type="image/webp" />
          <img src="/estudio.jpg" alt="Estúdio Cristal Studios" loading="lazy" width="1200" height="800" />
        </picture>
      </div>
    </div>
  </section>

</LandingPage>

<style>
  .lp-hero { padding: 5rem 0 4rem; }
  .lp-btn-hero { font-size: 1.05rem; padding: 1rem 2rem; }
  .lp-badge { margin-top: 1rem; color: #aaa; font-size: 0.88rem; }

  /* COMPARATIVO */
  .lp-comparativo { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2rem; }
  .lp-comp-card { border-radius: 14px; padding: 1.75rem; }
  .lp-comp-antes { background: #1a1010; border: 1px solid #3a2020; }
  .lp-comp-depois { background: #0f1a0f; border: 1px solid rgba(232,130,26,0.3); }
  .lp-comp-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #666; margin-bottom: 1rem; }
  .lp-comp-label-amber { color: var(--amber); }
  .lp-comp-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .lp-comp-card li { font-size: 0.92rem; color: #ccc; line-height: 1.5; }

  /* STEPS */
  .lp-steps { display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem; }
  .lp-step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .lp-step-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: var(--amber); color: #000; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
  }
  .lp-step strong { display: block; margin-bottom: 0.25rem; }
  .lp-step p { color: var(--text-muted); font-size: 0.9rem; }

  /* CARDS */
  .lp-icon { font-size: 2rem; margin-bottom: 1rem; }
  .lp-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .lp-card p { color: var(--text-muted); font-size: 0.88rem; line-height: 1.6; }

  /* CTA FINAL */
  .lp-cta-final { background: var(--amber); padding: 0; overflow: hidden; }
  .lp-cta-final-grid { display: grid; grid-template-columns: 1fr 420px; min-height: 400px; }
  .lp-cta-texto {
    padding: 4rem; display: flex; flex-direction: column;
    justify-content: center; gap: 1.25rem;
  }
  .lp-cta-texto h2 { color: #000; }
  .lp-cta-texto h2 .highlight { color: rgba(0,0,0,0.5); }
  .lp-cta-texto p { color: rgba(0,0,0,0.7); }
  .lp-cta-final .lp-btn { background: #000; color: #fff; align-self: flex-start; }
  .lp-cta-final .lp-btn:hover { background: #1a1a1a; }
  .lp-cta-sub { font-size: 0.82rem !important; color: rgba(0,0,0,0.55) !important; }
  .lp-cta-foto { overflow: hidden; }
  .lp-cta-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 768px) {
    .lp-comparativo { grid-template-columns: 1fr; }
    .lp-cta-final-grid { grid-template-columns: 1fr; }
    .lp-cta-foto { height: 240px; }
    .lp-cta-texto { padding: 2.5rem 1.5rem; }
    .lp-cta-final .lp-btn { align-self: stretch; justify-content: center; }
  }
</style>
