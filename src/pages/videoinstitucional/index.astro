---
import LandingPage from '../../layouts/LandingPage.astro';
import Depoimentos from '../../components/Depoimentos.astro';
import LeadForm from '../../components/LeadForm.astro';
import OfertaPacote from '../../components/OfertaPacote.astro';

const WA_NUMBER = "5519974062004";
const WA_MSG = encodeURIComponent("Olá! Vim pela página de Vídeo Institucional e quero um orçamento para minha empresa.");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;

const WA_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---

<LandingPage
  title="Vídeo Institucional Profissional: Cristal Studios | Campinas/SP"
  description="Vídeos institucionais que posicionam sua empresa como referência. Produção completa: roteiro, gravação, edição e entrega. Campinas/SP."
>

  <!-- HERO -->
  <section class="lp-section lp-hero">
    <div class="lp-container">
      <span class="lp-tag">Vídeo Institucional</span>
      <h1 class="lp-h1">
        Sua empresa vista como <span class="highlight">líder do mercado.</span>
      </h1>
      <p class="lp-lead">
        Um vídeo institucional bem feito vale mais do que mil argumentos de venda. Mostramos quem você é, o que entrega e por que o cliente deve escolher você, com produção que transmite confiança desde o primeiro frame.
      </p>
      <a href="#form" class="lp-btn">
        <Fragment set:html={WA_ICON} />
        Quero um orçamento
      </a>
    </div>
  </section>

  <!-- PARA QUEM É -->
  <section class="lp-section lp-section-dark">
    <div class="lp-container">
      <span class="lp-tag">Para quem é</span>
      <h2 class="lp-h2">Ideal para <span class="highlight">empresas que querem crescer</span></h2>
      <div class="lp-grid-2">
        <div class="lp-card lp-check-card">
          <ul class="lp-checklist">
            <li>✓ Empresas que querem presença profissional no digital</li>
            <li>✓ Negócios em processo de expansão ou reposicionamento</li>
            <li>✓ Marcas que precisam de vídeo para site, LinkedIn ou apresentação</li>
            <li>✓ Empresários que querem gerar confiança antes da reunião</li>
          </ul>
        </div>
        <div class="lp-card lp-entrega-card">
          <h3>O que você recebe</h3>
          <ul class="lp-checklist">
            <li>🎬 Roteiro estratégico alinhado à sua marca</li>
            <li>🎥 Gravação em estúdio ou na sua empresa</li>
            <li>🎞️ Edição profissional com trilha e motion</li>
            <li>📦 Arquivos em múltiplos formatos</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="lp-section">
    <div class="lp-container">
      <span class="lp-tag">Processo</span>
      <h2 class="lp-h2">Do briefing ao vídeo aprovado em <span class="highlight">4 etapas</span></h2>
      <div class="lp-steps">
        <div class="lp-step"><span class="lp-step-num">1</span><div><strong>Briefing e Roteiro</strong><p>Entendemos sua empresa, público e objetivo. Criamos o roteiro estratégico.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">2</span><div><strong>Gravação</strong><p>Estúdio profissional ou gravação externa na sua empresa.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">3</span><div><strong>Edição e Pós-Produção</strong><p>Corte, trilha, motion graphics, legendas e identidade visual aplicada.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">4</span><div><strong>Entrega e Revisão</strong><p>Você aprova, ajustamos se necessário e entregamos os arquivos finais.</p></div></div>
      </div>
    </div>
  </section>

  <OfertaPacote
    nome="Vídeo que Posiciona"
    itens={[
      "Roteiro estratégico alinhado à sua marca e ao seu objetivo",
      "Gravação em estúdio profissional ou na sua empresa",
      "Edição completa com trilha, motion graphics e legendas",
      "Identidade visual da sua marca aplicada no vídeo",
      "Arquivos em múltiplos formatos: site, redes e apresentações",
    ]}
    bonus="cortes verticais do seu vídeo para Reels, Stories e LinkedIn"
    garantia="Você aprova o roteiro antes de gravar e o corte final antes da entrega. Nada vai ao ar sem o seu sim."
  />

  <!-- CTA FINAL -->
  <section class="lp-section lp-cta-final">
    <div class="lp-container lp-cta-inner">
      <h2 class="lp-h2">Sua empresa merece ser vista <span class="highlight">do jeito certo.</span></h2>
      <p>Solicite um orçamento sem compromisso.</p>
      <a href="#form" class="lp-btn">
        <Fragment set:html={WA_ICON} />
        Falar com a Cristal Studios
      </a>
    </div>
  </section>

  <Depoimentos />

  <LeadForm servico="Vídeo Institucional" titulo="Sua empresa merece ser vista do jeito certo." texto="Preencha seus dados e continue no WhatsApp. Orçamento sem compromisso." />

</LandingPage>

<style>
  .lp-hero { padding-top: 5rem; padding-bottom: 5rem; }
  .lp-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
  .lp-checklist { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .lp-checklist li { color: #ccc; font-size: 0.95rem; line-height: 1.5; }
  .lp-check-card, .lp-entrega-card { display: flex; flex-direction: column; justify-content: center; }
  .lp-steps { display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem; }
  .lp-step { display: flex; align-items: flex-start; gap: 1.25rem; }
  .lp-step-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: var(--amber); color: #000; font-weight: 900; font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
  }
  .lp-step strong { display: block; font-size: 1rem; margin-bottom: 0.25rem; }
  .lp-step p { color: var(--text-muted); font-size: 0.9rem; }
  .lp-cta-final { background: var(--dark); }
  .lp-cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
  .lp-cta-inner p { color: #aaa; }
</style>
