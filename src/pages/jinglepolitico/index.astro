---
import LandingPage from '../../layouts/LandingPage.astro';

const WA_NUMBER = "5519974062004";
const WA_MSG = encodeURIComponent("Olá! Vim pela página de Jingle Político e quero um orçamento para minha campanha.");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;

const WA_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---

<LandingPage
  title="Jingle Político Profissional — Cristal Studios | Campinas/SP"
  description="Jingles políticos que engajam e fixam o nome do candidato. Produção completa para campanhas eleitorais: composição, locução e entrega rápida."
>

  <!-- HERO -->
  <section class="lp-section lp-hero">
    <div class="lp-container">
      <span class="lp-tag">Jingle Político</span>
      <h1 class="lp-h1">
        O eleitor lembra de <span class="highlight">quem ele ouve.</span>
      </h1>
      <p class="lp-lead">
        Na política, presença sonora é presença de voto. Criamos jingles que grudam na memória do eleitor — com agilidade para os prazos da campanha e qualidade de estúdio profissional.
      </p>
      <a href={WA_LINK} target="_blank" rel="noopener" class="lp-btn">
        <Fragment set:html={WA_ICON} />
        Solicitar orçamento da campanha
      </a>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="lp-section lp-section-dark">
    <div class="lp-container">
      <span class="lp-tag">Diferenciais</span>
      <h2 class="lp-h2">Feito para <span class="highlight">vencer eleições</span></h2>
      <div class="lp-grid-3">
        <div class="lp-card">
          <div class="lp-icon">⚡</div>
          <h3>Entrega Rápida</h3>
          <p>Sabemos que campanhas têm prazos. Trabalhamos com urgência sem perder qualidade.</p>
        </div>
        <div class="lp-card">
          <div class="lp-icon">🎯</div>
          <h3>Mensagem Estratégica</h3>
          <p>Letra e melodia alinhadas ao posicionamento do candidato e ao perfil do eleitorado.</p>
        </div>
        <div class="lp-card">
          <div class="lp-icon">📻</div>
          <h3>Todas as Mídias</h3>
          <p>Pronto para rádio, carros de som, redes sociais, TV e material impresso com QR Code.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="lp-section">
    <div class="lp-container">
      <span class="lp-tag">Processo</span>
      <h2 class="lp-h2">Do briefing ao jingle em <span class="highlight">4 etapas</span></h2>
      <div class="lp-steps">
        <div class="lp-step"><span class="lp-step-num">1</span><div><strong>Briefing Político</strong><p>Candidato, cargo, região, propostas principais e tom da campanha.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">2</span><div><strong>Composição</strong><p>Criamos melodia e letra que fixam o nome e a proposta.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">3</span><div><strong>Gravação</strong><p>Estúdio profissional com locução e arranjo musical sob medida.</p></div></div>
        <div class="lp-step"><span class="lp-step-num">4</span><div><strong>Entrega nos formatos</strong><p>MP3, WAV e versões editadas para cada tipo de mídia da campanha.</p></div></div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="lp-section lp-cta-final">
    <div class="lp-container lp-cta-inner">
      <h2 class="lp-h2">Sua campanha merece um jingle <span class="highlight">que vence.</span></h2>
      <p>Fale com a Cristal Studios agora e garanta sua produção no prazo.</p>
      <a href={WA_LINK} target="_blank" rel="noopener" class="lp-btn">
        <Fragment set:html={WA_ICON} />
        Falar com a Cristal Studios
      </a>
    </div>
  </section>

</LandingPage>

<style>
  .lp-hero { padding-top: 5rem; padding-bottom: 5rem; }
  .lp-icon { font-size: 2rem; margin-bottom: 1rem; }
  .lp-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .lp-card p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; }
  .lp-steps { display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem; }
  .lp-step { display: flex; align-items: flex-start; gap: 1.25rem; }
  .lp-step-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: var(--amber); color: #000; font-weight: 900; font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
  }
  .lp-step strong { display: block; font-size: 1rem; margin-bottom: 0.25rem; }
  .lp-step p { color: var(--text-muted); font-size: 0.9rem; }
  .lp-cta-final { background: var(--dark); }
  .lp-cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
  .lp-cta-inner p { color: #aaa; }
</style>
