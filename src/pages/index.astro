---
import Layout from '../layouts/Layout.astro';

const WA_NUMBER = "5519974062004";
const WA_MSG = encodeURIComponent("Olá! Vim pelo site e quero saber mais sobre os serviços da Cristal Studios.");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;
const WA_MSG_PODCAST = encodeURIComponent("Olá! Tenho interesse em produzir um podcast com a Cristal Studios. Quero agendar um diagnóstico gratuito.");
const WA_LINK_PODCAST = `https://wa.me/${WA_NUMBER}?text=${WA_MSG_PODCAST}`;
---

<Layout
  title="Cristal Studios — Podcast, Vídeo e Áudio Profissional em Campinas/SP"
  description="Produtora de podcast, vídeo institucional, jingles e estratégia de conteúdo em Campinas/SP. +40 anos de experiência. Diagnóstico gratuito."
>

  <!-- HERO FULL-BLEED (vídeo/imagem) -->
  <section class="hero-full" id="home">
    <video
      class="hero-bg"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/hero-poster.jpg"
    >
      <source src="/hero.webm" type="video/webm" />
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-vignette"></div>

    <div class="hero-bottom">
      <div class="hero-text">
        <h1 class="hero-headline">
          <span><strong>Quem não é visto,</strong> é comparado.</span>
          <span><strong>Quem é autoridade,</strong> é escolhido.</span>
        </h1>
        <p class="hero-subline">
          Podcast, vídeo e conteúdo estratégico para posicionar sua marca no próximo nível.
        </p>
        <a href={WA_LINK} target="_blank" rel="noopener" class="hero-cta">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Quero agendar uma visita
        </a>
      </div>
      <div class="hero-badges">
        <span class="hero-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M5 12h14"/></svg>
          +40 anos de mercado
        </span>
        <span class="hero-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Produção completa
        </span>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section class="section" id="producoes">
    <div class="container">
      <div class="section-tag">O QUE FAZEMOS</div>
      <h2>Produção profissional do início ao fim.<br /><span class="highlight">Você tem a ideia. A gente entrega o resultado.</span></h2>
      <p class="section-sub">Não somos apenas um estúdio. Somos parceiros estratégicos — cuidamos de tudo: roteiro, gravação, edição, publicação e distribuição.</p>

      <div class="servicos-grid">

        <!-- PODCAST -->
        <div class="servico-card" id="podcast">
          <div class="servico-icon">🎙️</div>
          <h3>Podcasts Estratégicos</h3>
          <p>Transforme sua expertise em um canal de autoridade. Produzimos e posicionamos seu videocast com qualidade broadcast e estratégia de conteúdo que gera negócios.</p>
          <ul class="servico-list">
            <li>Estúdios equipados para gravação de áudio e vídeo</li>
            <li>Roteiro, direção, gravação, edição e publicação</li>
            <li>Estratégia de conteúdo e distribuição multicanal</li>
            <li>Cortes para redes sociais e performance digital</li>
          </ul>
          <a href={WA_LINK_PODCAST} target="_blank" rel="noopener" class="btn-servico">Quero meu podcast →</a>
        </div>

        <!-- VÍDEO -->
        <div class="servico-card" id="video">
          <div class="servico-icon">🎬</div>
          <h3>Vídeos Institucionais e Comerciais</h3>
          <p>Vídeos pensados para impactar, gerar confiança e vender. Da ideia ao roteiro, da filmagem à edição — cuidamos de tudo com talento e profissionalismo.</p>
          <ul class="servico-list">
            <li>Vídeos para sites, redes sociais e anúncios</li>
            <li>Captação com equipe técnica experiente</li>
            <li>Motion graphics, trilha sonora e pós-produção premium</li>
            <li>Edição em Final Cut Pro, DaVinci Resolve, After Effects</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn-servico">Quero meu vídeo →</a>
        </div>

        <!-- JINGLES -->
        <div class="servico-card" id="jingles">
          <div class="servico-icon">🎵</div>
          <h3>Jingles e Produção de Áudio</h3>
          <p>Comunicação sonora profissional que gera memórias e posiciona marcas. Quem ouve, lembra. Quem lembra, compra.</p>
          <ul class="servico-list">
            <li>Jingles publicitários, institucionais e eleitorais</li>
            <li>Spots de rádio, programas e podcasts</li>
            <li>Identidade sonora exclusiva para marcas (signo sonoro)</li>
            <li>Áudio livros e áudio contos</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn-servico">Quero meu jingle →</a>
        </div>

        <!-- ESTRATÉGIA -->
        <div class="servico-card" id="estrategia">
          <div class="servico-icon">📊</div>
          <h3>Estratégia e Distribuição</h3>
          <p>Conteúdo sem estratégia é apenas ruído. Nós criamos, publicamos e promovemos com inteligência e dados para que seu conteúdo chegue às pessoas certas.</p>
          <ul class="servico-list">
            <li>Planejamento editorial e de SEO</li>
            <li>Otimização para Spotify, YouTube, Apple Podcasts</li>
            <li>Estratégia de cortes e campanhas em redes sociais</li>
            <li>Estudo de posicionamento e autoridade</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn-servico">Quero minha estratégia →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ESTÚDIO -->
  <section class="section section-dark" id="estudios">
    <div class="container">
      <div class="estudio-grid">
        <div class="estudio-text">
          <div class="section-tag">O ESTÚDIO</div>
          <h2>Infraestrutura de <span class="highlight">nível broadcast</span> no coração de Campinas.</h2>
          <p>Nossos estúdios foram desenvolvidos para proporcionar a melhor experiência de gravação — para você e para quem vai assistir. Ambiente profissional, climatizado, com tratamento acústico de alta performance.</p>
          <div class="estudio-features">
            <div class="estudio-feature">
              <span class="feature-icon">🎙️</span>
              <div>
                <strong>Áudio Broadcast</strong>
                <p>Microfones de estúdio, tratamento acústico e monitoramento profissional. Áudio impecável em todas as gravações.</p>
              </div>
            </div>
            <div class="estudio-feature">
              <span class="feature-icon">🎬</span>
              <div>
                <strong>Câmeras de Cinema</strong>
                <p>Equipamentos de alta resolução com iluminação de cinema. A imagem transmite credibilidade antes da primeira fala.</p>
              </div>
            </div>
            <div class="estudio-feature">
              <span class="feature-icon">💻</span>
              <div>
                <strong>Pós-Produção Premium</strong>
                <p>Final Cut Pro, DaVinci Resolve Studio, Pro Tools, UAD Luna, After Effects, Blender e ferramentas de IA de última geração.</p>
              </div>
            </div>
            <div class="estudio-feature">
              <span class="feature-icon">☕</span>
              <div>
                <strong>Ambiente Completo</strong>
                <p>Áreas de convivência, conforto total para clientes e visitantes. Você chega, relaxa e foca no que importa: conteúdo.</p>
              </div>
            </div>
          </div>
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn-primary" style="margin-top:0.5rem">Agendar visita ao estúdio</a>
        </div>
        <div class="estudio-img">
          <img src="/estudio.jpg" alt="Estúdio Cristal Studios" />
          <div class="estudio-badge">
            <span class="eb-num">+40</span>
            <span class="eb-label">anos de experiência</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EMPRESA / POR QUE CRISTAL -->
  <section class="section" id="empresa">
    <div class="container">
      <div class="section-tag">A EMPRESA</div>
      <h2>Quatro décadas criando <span class="highlight">conteúdo que conecta.</span></h2>
      <p class="section-sub">A Cristal Studios nasceu em 1984 e cresceu junto com o mercado de comunicação. Passamos pela era do rádio, do vídeo analógico, da internet e do streaming — sempre na vanguarda, sempre entregando qualidade.</p>

      <div class="valores-grid">
        <div class="valor-card">
          <div class="valor-icon">🎯</div>
          <h3>Foco em Resultado</h3>
          <p>Toda entrega da Cristal tem um propósito claro: gerar autoridade, engajamento e conversão para o seu negócio.</p>
        </div>
        <div class="valor-card">
          <div class="valor-icon">📖</div>
          <h3>+40 Anos de História</h3>
          <p>Quem tem história sabe contar histórias que conectam. Nossa experiência é o que transforma boa produção em resultado real.</p>
        </div>
        <div class="valor-card">
          <div class="valor-icon">🤝</div>
          <h3>Atendimento Consultivo</h3>
          <p>Você não precisa saber nada de produção. Cuidamos de tudo — e ainda ajudamos com estratégia de conteúdo e posicionamento.</p>
        </div>
        <div class="valor-card">
          <div class="valor-icon">🏢</div>
          <h3>Infraestrutura Completa</h3>
          <p>Estúdios modernos em Campinas/SP com ambiente profissional, climatizado e pronto para receber sua marca.</p>
        </div>
        <div class="valor-card">
          <div class="valor-icon">🚀</div>
          <h3>Parceria Estratégica</h3>
          <p>Não somos só produtores. Atuamos como parceiros para fazer sua marca crescer com conteúdo inteligente e consistente.</p>
        </div>
        <div class="valor-card">
          <div class="valor-icon">⚡</div>
          <h3>Entrega Ágil</h3>
          <p>Processo estruturado e equipe dedicada. Seu conteúdo editado e entregue em até 5 dias úteis — sem perder qualidade.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEPOIMENTOS -->
  <section class="section section-dark" id="historias">
    <div class="container">
      <div class="section-tag">O QUE DIZEM NOSSOS CLIENTES</div>
      <h2>Marcas que confiam na <span class="highlight">Cristal Studios.</span></h2>
      <p class="section-sub">Empresários e marcas de Campinas e região que transformaram suas ideias em conteúdo de alto impacto.</p>
      <div class="depo-grid">
        <div class="depo-card">
          <div class="stars">★★★★★</div>
          <p>"A Cristal Studios mudou completamente como o mercado me enxerga. Meus clientes chegam dizendo que me acompanham há meses antes de fechar negócio. Isso não tem preço."</p>
          <div class="depo-autor">
            <div class="avatar">F</div>
            <div>
              <strong>Fábio</strong>
              <span>Empresário · Campinas/SP</span>
            </div>
          </div>
        </div>
        <div class="depo-card">
          <div class="stars">★★★★★</div>
          <p>"Eu tinha medo de não saber falar para câmera. A equipe me colocou à vontade desde o primeiro segundo. O resultado ficou muito mais profissional do que eu imaginava."</p>
          <div class="depo-autor">
            <div class="avatar">O</div>
            <div>
              <strong>Olga</strong>
              <span>Empreendedora · Campinas/SP</span>
            </div>
          </div>
        </div>
        <div class="depo-card">
          <div class="stars">★★★★★</div>
          <p>"Trabalho com a Cristal há anos. A qualidade do áudio e a atenção estratégica ao conteúdo são incomparáveis. É o tipo de parceria que faz diferença no resultado final."</p>
          <div class="depo-autor">
            <div class="avatar">M</div>
            <div>
              <strong>Marcos</strong>
              <span>Diretor Comercial · Campinas/SP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner-inner">
        <div>
          <h2>Pronto para começar?<br /><span class="highlight">O diagnóstico é gratuito.</span></h2>
          <p>30 minutos de conversa. Saímos com um plano claro para o seu conteúdo.</p>
        </div>
        <a href={WA_LINK_PODCAST} target="_blank" rel="noopener" class="btn-primary btn-xl">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar no WhatsApp agora
        </a>
      </div>
    </div>
  </section>

  <!-- CONTATO -->
  <section class="section" id="contato">
    <div class="container">
      <div class="contato-grid">
        <div>
          <div class="section-tag">CONTATO</div>
          <h2>Vamos criar algo <span class="highlight">incrível juntos.</span></h2>
          <p class="section-sub" style="margin-bottom:2rem">Entre em contato pelo canal que preferir. Respondemos em menos de 1 hora útil.</p>
          <div class="contato-items">
            <a href={WA_LINK} target="_blank" rel="noopener" class="contato-item">
              <span class="contato-icon">💬</span>
              <div>
                <strong>WhatsApp</strong>
                <span>(19) 9 97406-2004</span>
              </div>
            </a>
            <a href="mailto:relacionamento@cristalstudios.com" class="contato-item">
              <span class="contato-icon">✉️</span>
              <div>
                <strong>E-mail</strong>
                <span>relacionamento@cristalstudios.com</span>
              </div>
            </a>
            <div class="contato-item">
              <span class="contato-icon">📍</span>
              <div>
                <strong>Endereço</strong>
                <span>Rua Arlindo Carpino, 20 — Novo Taquaral<br />Campinas/SP · CEP 13077-101</span>
              </div>
            </div>
            <div class="contato-item">
              <span class="contato-icon">🕐</span>
              <div>
                <strong>Atendimento</strong>
                <span>Segunda a sexta, das 9h às 18h</span>
              </div>
            </div>
          </div>
          <div class="social-links">
            <a href="https://instagram.com/cristalstudiosproducoes" target="_blank" rel="noopener" class="social-btn">Instagram</a>
            <a href="https://youtube.com/@cristalstudios" target="_blank" rel="noopener" class="social-btn">YouTube</a>
            <a href="https://linkedin.com/company/cristalstudios" target="_blank" rel="noopener" class="social-btn">LinkedIn</a>
            <a href="https://facebook.com/cristalstudios" target="_blank" rel="noopener" class="social-btn">Facebook</a>
          </div>
        </div>
        <div class="contato-cta-box">
          <div class="section-tag">DIAGNÓSTICO GRATUITO</div>
          <h3>Uma conversa.<br />Um plano claro.</h3>
          <p>Conte sobre seu negócio e seus objetivos. Em 30 minutos, entregamos um diagnóstico personalizado e uma proposta com formato e investimento.</p>
          <ul class="check-list">
            <li>✓ Sem compromisso</li>
            <li>✓ Diagnóstico personalizado para seu segmento</li>
            <li>✓ Proposta com investimento claro</li>
            <li>✓ Resposta em menos de 1 hora útil</li>
          </ul>
          <a href={WA_LINK_PODCAST} target="_blank" rel="noopener" class="btn-primary" style="width:100%;justify-content:center;margin-top:1rem">
            Agendar diagnóstico gratuito
          </a>
        </div>
      </div>
    </div>
  </section>


</Layout>

<style>
  /* ═══════════════════════════════════════════════
     HERO FULL-BLEED com vídeo
     ═══════════════════════════════════════════════ */
  .hero-full {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background: #000;
  }
  .hero-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-vignette {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 30%, transparent 50%, rgba(0,0,0,0.85) 100%),
      linear-gradient(90deg, rgba(0,0,0,0.3) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero-bottom {
    position: absolute;
    bottom: 4rem; left: 0; right: 0;
    z-index: 2;
    display: flex; align-items: flex-end; justify-content: space-between;
    padding: 0 4rem;
    gap: 2rem;
  }
  .hero-text {
    display: flex; flex-direction: column; gap: 1.2rem;
    flex: 1; min-width: 0;
  }
  .hero-headline {
    font-size: clamp(1.6rem, 3.2vw, 3rem);
    font-weight: 300;
    line-height: 1.18;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero-headline span {
    display: block;
    white-space: nowrap;
  }
  .hero-headline strong {
    font-weight: 800;
    color: #fff;
  }
  .hero-subline {
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255,255,255,0.88);
    margin: 0;
    max-width: 620px;
  }
  .hero-cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: var(--amber); color: #000;
    font-weight: 700; font-size: 1rem;
    padding: 0.95rem 1.7rem; border-radius: 100px;
    text-decoration: none; margin-top: 0.4rem;
    box-shadow: 0 6px 24px rgba(232,130,26,0.35);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    background: var(--amber-light);
    box-shadow: 0 10px 32px rgba(232,130,26,0.5);
  }
  .hero-cta svg { flex-shrink: 0; }
  .hero-badges {
    display: flex; flex-direction: column; gap: 0.7rem;
    align-items: flex-end;
    flex-shrink: 0;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.6rem;
    color: #fff; font-size: 0.95rem; font-weight: 500;
  }
  .hero-badge svg {
    color: var(--amber);
    flex-shrink: 0;
  }

  /* ─── MOBILE HERO ─── */
  @media (max-width: 900px) {
    .hero-bottom {
      flex-direction: column; align-items: flex-start;
      padding: 0 1.5rem; bottom: 2rem; gap: 1.5rem;
    }
    .hero-headline span { white-space: normal; }
    .hero-badges {
      flex-direction: row; align-items: flex-start; gap: 1.2rem;
      flex-wrap: wrap;
    }
    .hero-badge { font-size: 0.85rem; }
  }

  /* ─── HERO LEGACY (split layout — sem uso na home atual mas mantido pra outras pages) ─── */
  .hero {
    display: grid; grid-template-columns: 1fr 1fr;
    min-height: 91vh; align-items: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; top: -20%; left: -10%;
