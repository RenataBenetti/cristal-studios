    content: ''; position: absolute; inset: -8px; border-radius: 24px;
    background: radial-gradient(60% 75% at 50% 25%, rgba(232,130,26,0.5), rgba(232,130,26,0) 72%);
    opacity: 0; z-index: -1; filter: blur(24px); transition: opacity 0.4s ease; pointer-events: none;
  }
  .prod-card:hover {
    border-color: var(--amber); transform: translateY(-4px);
    box-shadow: 0 18px 50px rgba(0,0,0,0.5), 0 0 36px rgba(232,130,26,0.22);
  }
  .prod-card:hover::before { opacity: 1; }
  .prod-media {
    position: relative; aspect-ratio: 16 / 9;
    border-radius: 18px 18px 0 0; overflow: hidden;
    background: linear-gradient(135deg, #1d1d1d 0%, #0c0c0c 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .prod-media video, .prod-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-media-icon { font-size: 3.2rem; opacity: 0.45; }
  .prod-media-badge {
    position: absolute; top: 0.8rem; right: 0.8rem;
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
    color: #ccc; background: rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.15);
    padding: 0.25rem 0.6rem; border-radius: 100px;
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }
  .prod-body { padding: 1.6rem; }
  .prod-body h3 { font-size: 1.2rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.8rem; }
  .prod-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.9rem; }
  .prod-tag {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em;
    color: var(--amber); background: rgba(232,130,26,0.12);
    border: 1px solid rgba(232,130,26,0.3);
    padding: 0.25rem 0.65rem; border-radius: 100px;
  }
  .prod-body p { color: #999; font-size: 0.93rem; line-height: 1.6; margin: 0; }

  /* ─── COMO FUNCIONA ─── */
  .cf-head { text-align: center; max-width: 840px; margin: 0 auto; }
  .cf-head h2 { font-size: clamp(1.7rem, 3vw, 2.6rem); font-weight: 800; line-height: 1.15; margin-bottom: 1.2rem; }
  .cf-intro { color: #aaa; font-size: 1.05rem; line-height: 1.75; max-width: 720px; margin: 0 auto; }
  .steps {
    list-style: none; padding: 0; margin: 4rem 0 0;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.8rem;
    position: relative;
  }
  .steps::before {
    content: ''; position: absolute; top: 34px;
    left: 12.5%; right: 12.5%; height: 2px;
    background: linear-gradient(90deg, rgba(232,130,26,0.15), rgba(232,130,26,0.65), rgba(232,130,26,0.15));
    z-index: 0;
  }
  .step { position: relative; text-align: center; padding: 0 0.4rem; }
  .step-num {
    position: relative; z-index: 2;
    width: 68px; height: 68px; border-radius: 50%;
    background: linear-gradient(135deg, var(--amber), #a85309);
    color: #000; font-size: 1.6rem; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.3rem;
    box-shadow:
      0 0 0 8px rgba(232,130,26,0.12),
      0 0 22px rgba(232,130,26,0.7),
      0 0 48px rgba(232,130,26,0.45),
      0 10px 28px rgba(232,130,26,0.35);
  }
  .step-label { display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; color: var(--amber); text-transform: uppercase; margin-bottom: 0.45rem; }
  .step h3 { font-size: 1.12rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.7rem; }
  .step p { color: #999; font-size: 0.9rem; line-height: 1.62; margin: 0; }
  .cf-closing {
    margin-top: 5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 20px; overflow: hidden;
  }
  .cf-closing-img img { width: 100%; height: 100%; min-height: 340px; object-fit: cover; display: block; }
  .cf-closing-text { padding: 3rem; }
  .cf-closing-text h3 { font-size: clamp(1.4rem, 2.4vw, 2rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .cf-closing-text p { color: #aaa; font-size: 1rem; line-height: 1.75; margin-bottom: 1.5rem; }

  /* ─── ESTÚDIO ─── */
  .estudio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .estudio-text { display: flex; flex-direction: column; gap: 1rem; }
  .estudio-text p { color: #999; font-size: 1rem; line-height: 1.75; margin-bottom: 1rem; }
  .estudio-features { display: flex; flex-direction: column; gap: 1.2rem; margin: 1rem 0; }
  .estudio-feature { display: flex; gap: 1rem; align-items: flex-start; }
  .feature-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
  .estudio-feature strong { display: block; font-size: 0.95rem; margin-bottom: 0.2rem; }
  .estudio-feature p { color: #888; font-size: 0.88rem; line-height: 1.5; margin: 0; }
  .estudio-img { position: relative; border-radius: 16px; overflow: hidden; }
  .estudio-img img { width: 100%; height: 500px; object-fit: cover; display: block; border-radius: 16px; }
  .estudio-badge {
    position: absolute; bottom: 1.5rem; left: 1.5rem;
    background: rgba(10,10,10,0.9); border: 1px solid var(--amber);
    border-radius: 12px; padding: 1rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.1rem;
  }
  .eb-num { font-size: 2rem; font-weight: 900; color: var(--amber); line-height: 1; }
  .eb-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; color: #888; text-transform: uppercase; }

  /* ─── ESTRUTURA / COVERFLOW ─── */
  .estudios { overflow: hidden; }
  .estrutura-head { max-width: 820px; margin: 0 auto; text-align: center; }
  .estrutura-tag { display: inline-block; }
  .estrutura-title { font-size: clamp(1.7rem, 3.4vw, 2.7rem); font-weight: 800; line-height: 1.15; margin-bottom: 1.2rem; }
  .estrutura-sub { color: #aaa; font-size: 1.05rem; line-height: 1.75; max-width: 700px; margin: 0 auto; }

  .coverflow {
    position: relative;
    margin-top: 3.5rem;
    height: 560px;
    perspective: 1900px;
    display: flex; align-items: center; justify-content: center;
  }
  .cf-stage {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
  }
  .cf-item {
    position: absolute; top: 50%; left: 50%;
    width: min(760px, 52vw); height: 480px;
    margin: 0; border-radius: 18px; overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.6);
    transition: transform 0.6s cubic-bezier(0.22,0.61,0.36,1), opacity 0.6s ease, box-shadow 0.4s ease;
    will-change: transform, opacity;
    cursor: pointer;
  }
  .cf-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cf-item::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,0.55));
    opacity: 0; transition: opacity 0.5s ease;
  }
  .cf-item.is-side::after { opacity: 1; }
  .cf-item.is-active {
    box-shadow: 0 30px 80px rgba(0,0,0,0.7),
      0 0 0 1px rgba(232,130,26,0.55),
      0 0 70px rgba(232,130,26,0.28);
  }

  .cf-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 50; width: 52px; height: 52px; border-radius: 50%;
    background: rgba(10,10,10,0.8);
    border: 1px solid rgba(232,130,26,0.5);
    color: var(--amber);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    transition: background 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .cf-prev { left: 2.5vw; }
  .cf-next { right: 2.5vw; }
  .cf-arrow:hover { background: var(--amber); color: #000; box-shadow: 0 0 24px rgba(232,130,26,0.6); }

  .cf-dots { position: absolute; bottom: -0.5rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.5rem; z-index: 50; }
  .cf-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.25); border: none; cursor: pointer; padding: 0; transition: background 0.25s, width 0.25s; }
  .cf-dot.active { background: var(--amber); width: 22px; border-radius: 4px; }

  /* ─── INFRAESTRUTURA ─── */
  .infra { margin-top: 6rem; }
  .infra-top {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: start; margin-bottom: 4rem;
  }
  .infra-intro h2 { font-size: clamp(1.7rem, 3vw, 2.6rem); font-weight: 800; line-height: 1.15; margin-bottom: 1.2rem; }
  .infra-intro p { color: #aaa; font-size: 1rem; line-height: 1.75; margin-bottom: 1.1rem; }
  .infra-checklist { list-style: none; padding: 0; margin: 0.4rem 0 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .infra-checklist li { position: relative; padding-left: 2.2rem; color: #ccc; font-size: 0.98rem; line-height: 1.5; }
  .infra-checklist li::before {
    content: '✓'; position: absolute; left: 0; top: 0.05rem;
    width: 1.4rem; height: 1.4rem; border-radius: 50%;
    background: var(--amber); color: #000;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem; font-weight: 800;
  }
  .infra-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .infra-card {
    position: relative; z-index: 0;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; padding: 2rem;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .infra-card::before {
    content: ''; position: absolute; inset: -8px;
    border-radius: 22px;
    background: radial-gradient(60% 75% at 50% 25%, rgba(232,130,26,0.5), rgba(232,130,26,0) 72%);
    opacity: 0; z-index: -1; filter: blur(24px);
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .infra-card:hover {
    border-color: var(--amber); transform: translateY(-4px);
    box-shadow: 0 18px 50px rgba(0,0,0,0.5), 0 0 36px rgba(232,130,26,0.22);
  }
  .infra-card:hover::before { opacity: 1; }
  .infra-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .infra-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; line-height: 1.3; }
  .infra-card p { color: #999; font-size: 0.92rem; line-height: 1.65; margin: 0; }

  /* ─── CENÁRIOS (carrossel vertical) ─── */
  .cenarios { margin-top: 6rem; }
  .cenarios-head { text-align: center; max-width: 860px; margin: 0 auto 3rem; }
  .cenarios-head h2 { font-size: clamp(1.7rem, 3vw, 2.6rem); font-weight: 800; line-height: 1.15; }
  .cenarios-body {
    display: grid; grid-template-columns: 1.05fr 1fr;
    gap: 4rem; align-items: center;
  }
  .vcar {
    position: relative;
    height: 580px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, transparent 0, #000 6%, #000 94%, transparent 100%);
    mask-image: linear-gradient(180deg, transparent 0, #000 6%, #000 94%, transparent 100%);
  }
  .vcar-track {
    display: flex; flex-direction: column; gap: 1.5rem;
    transition: transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
  }
  .vcar-card {
    position: relative; flex-shrink: 0;
    height: 480px; border-radius: 20px; overflow: hidden;
    box-shadow: 0 24px 50px rgba(0,0,0,0.55);
  }
  .vcar-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vcar-card::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.85));
  }
  .vcar-overlay {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 1.8rem 2rem; z-index: 2;
  }
  .vcar-overlay h3 { font-size: 1.4rem; font-weight: 800; margin: 0 0 0.4rem; color: #fff; }
  .vcar-overlay p { font-size: 0.95rem; line-height: 1.6; color: #d6d6d6; margin: 0; max-width: 30rem; }
  .vcar-dots {
    position: absolute; top: 50%; right: 0.8rem; transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 0.5rem; z-index: 5;
  }
  .vcar-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.3); border: none; cursor: pointer; padding: 0; transition: background 0.25s, height 0.25s; }
  .vcar-dot.active { background: var(--amber); height: 22px; border-radius: 4px; }
  .vcar-arrows {
    position: absolute; bottom: 1.2rem; left: 50%; transform: translateX(-50%);
    display: flex; gap: 0.75rem; z-index: 5;
  }
  .vcar-arrow {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    backdrop-filter: blur(6px);
  }
  .vcar-arrow:hover { background: var(--amber); border-color: var(--amber); transform: scale(1.1); }

  .cenarios-text p { color: #aaa; font-size: 1rem; line-height: 1.75; margin-bottom: 1.2rem; }

  .formatos-grid {
    margin-top: 4rem;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .formato-card {
    position: relative; z-index: 0;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; padding: 2rem;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .formato-card::before {
    content: ''; position: absolute; inset: -8px; border-radius: 22px;
    background: radial-gradient(60% 75% at 50% 25%, rgba(232,130,26,0.5), rgba(232,130,26,0) 72%);
    opacity: 0; z-index: -1; filter: blur(24px); transition: opacity 0.4s ease; pointer-events: none;
  }
  .formato-card:hover {
    border-color: var(--amber); transform: translateY(-4px);
    box-shadow: 0 18px 50px rgba(0,0,0,0.5), 0 0 36px rgba(232,130,26,0.22);
  }
  .formato-card:hover::before { opacity: 1; }
  .formato-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .formato-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; line-height: 1.3; }
  .formato-card p { color: #999; font-size: 0.92rem; line-height: 1.65; margin: 0; }

  /* ─── EMPRESA / VALORES ─── */
  .valores-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .valor-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 1.8rem;
    transition: border-color 0.2s;
  }
  .valor-card:hover { border-color: rgba(232,130,26,0.3); }
  .valor-icon { font-size: 2rem; margin-bottom: 0.8rem; display: block; }
  .valor-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .valor-card p { color: #888; font-size: 0.9rem; line-height: 1.6; }

  /* ─── DEPOIMENTOS CARROSSEL 3-SLOTS ─── */
  .depo-car {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; margin-top: 2.5rem;
  }
  .depo-viewport {
    display: flex; align-items: flex-start; justify-content: center;
    gap: 1rem; overflow: hidden;
  }
  .depo-slot {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.75rem; flex-shrink: 0; transition: opacity 0.4s, transform 0.4s;
  }
  .depo-slot-center { z-index: 2; }
  .depo-slot-side { opacity: 0.5; transform: scale(0.9); cursor: pointer; }
  .depo-slot-side:hover { opacity: 0.75; }
  .depo-video-wrap {
    position: relative; border-radius: 16px; overflow: hidden;
    background: #000; box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  }
  .depo-slot-center .depo-video-wrap { width: 310px; aspect-ratio: 9/16; }
  .depo-slot-side   .depo-video-wrap { width: 200px; aspect-ratio: 9/16; }
  .depo-video-wrap video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .depo-play-btn {
    position: absolute; inset: 0; display: flex;
    align-items: center; justify-content: center;
    background: rgba(0,0,0,0.4); color: #fff; cursor: pointer;
    transition: background 0.2s; border: none;
  }
  .depo-play-btn:hover { background: rgba(0,0,0,0.2); }
  .depo-play-btn.hidden { display: none; }
  .depo-caption { text-align: center; }
  .depo-caption strong { display: block; font-size: 0.95rem; color: #fff; font-weight: 700; }
  .depo-caption span { font-size: 0.78rem; color: var(--text-muted); }
  .depo-arr {
    width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: #fff; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }
  .depo-arr:hover { background: var(--amber); border-color: var(--amber); color: #000; }
  .depo-dots {
    display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.5rem;
  }
  .depo-dot {
    width: 8px; height: 8px; border-radius: 50%; padding: 0; border: none;
    background: rgba(255,255,255,0.25); cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .depo-dot.active { background: var(--amber); transform: scale(1.3); }
  @media (max-width: 680px) {
    .depo-slot-side { display: none; }
    .depo-slot-center .depo-video-wrap { width: min(200px, 58vw); }
    .depo-arr { width: 38px; height: 38px; }
  }

  /* ─── CTA BANNER ─── */
  /* ─── CTA BANNER (card escuro c/ marca d'água) ─── */
  .cta-banner { padding: 3rem 0; }
  .cta-card {
    position: relative; overflow: hidden;
    background: #100c08;
    border-radius: 20px;
    border: 1px solid rgba(229,160,35,0.15);
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem; flex-wrap: wrap;
    padding: 3.5rem 4rem 3.5rem 5rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }
  /* linha âmbar esquerda + glow */
  .cta-glow-line {
    position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: var(--amber);
    box-shadow: 0 0 32px 8px rgba(229,160,35,0.45), 0 0 80px 20px rgba(229,160,35,0.15);
  }
  /* marca d'água */
  .cta-watermark {
    position: absolute; left: -2%; top: 50%; transform: translateY(-50%);
    width: 320px; height: 320px; color: var(--amber);
    opacity: 0.07; pointer-events: none;
  }
  .cta-watermark svg { width: 100%; height: 100%; }
  /* conteúdo */
  .cta-left { position: relative; flex: 1; min-width: 280px; }
  .cta-left h2 {
    font-size: clamp(1.5rem, 2.8vw, 2.1rem); font-weight: 800;
    color: #fff; line-height: 1.3; margin: 0;
  }
  .cta-left h2 .highlight { color: var(--amber); }
  .cta-right { position: relative; display: flex; flex-direction: column; gap: 1rem; min-width: 260px; }
  .cta-right p { color: rgba(255,255,255,0.6); font-size: 0.95rem; margin: 0; }
  .btn-cta-card {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: var(--amber); color: #000; font-weight: 700;
    font-size: 1rem; padding: 0.9rem 1.8rem; border-radius: 10px;
    text-decoration: none; transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-cta-card:hover { background: #f5a800; transform: translateY(-1px); }
  @media (max-width: 768px) {
    .cta-card { padding: 2.5rem 2rem 2.5rem 2.5rem; flex-direction: column; }
    .cta-watermark { width: 220px; height: 220px; opacity: 0.05; }
  }

  /* ─── CONTATO ─── */
  .contato-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .contato-items { display: flex; flex-direction: column; gap: 1.2rem; margin-bottom: 2rem; }
  .contato-item {
    display: flex; align-items: flex-start; gap: 1rem;
    color: #fff; text-decoration: none;
    transition: color 0.2s;
  }
  a.contato-item:hover { color: var(--amber); }
  .contato-icon { font-size: 1.4rem; flex-shrink: 0; }
  .contato-item strong { display: block; font-size: 0.92rem; margin-bottom: 0.2rem; }
  .contato-item span { color: #999; font-size: 0.88rem; line-height: 1.5; }
  .social-links { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .social-btn {
    border: 1px solid var(--border); color: #aaa;
    font-size: 0.82rem; font-weight: 600;
    padding: 0.4rem 0.9rem; border-radius: 100px;
    text-decoration: none; transition: border-color 0.2s, color 0.2s;
  }
  .social-btn:hover { border-color: var(--amber); color: var(--amber); }
  .contato-cta-box {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; padding: 2.5rem;
  }
  .contato-cta-box h3 { font-size: 1.6rem; font-weight: 800; line-height: 1.2; margin: 0.5rem 0 1rem; }
  .contato-cta-box p { color: #999; font-size: 0.95rem; line-height: 1.7; margin-bottom: 1.5rem; }
  .check-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .check-list li { color: #bbb; font-size: 0.92rem; }

  /* ─── BRILHO NOS ÍCONES ─── */
