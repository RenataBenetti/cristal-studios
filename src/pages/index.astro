---
import Layout from '../layouts/Layout.astro';

const WA_NUMBER = "5519974062004";
const WA_MSG = encodeURIComponent("Olá! Vim pelo site e quero saber mais sobre os serviços da Cristal Studios.");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;
const WA_MSG_PODCAST = encodeURIComponent("Olá! Vim pelo site da Cristal Studios e gostaria de agendar uma visita ao estúdio.");
const WA_LINK_PODCAST = `https://wa.me/${WA_NUMBER}?text=${WA_MSG_PODCAST}`;

// Carrossel da ESTRUTURA — substitua por fotos reais do estúdio em /public/estudios/
const estruturaImgs = [
  { src: "/estudios/estrutura-4.jpg", alt: "Set de gravação com parede de pedra, painel acústico e tela com a marca Cristal Studios" },
  { src: "/estudios/estrutura-1.jpg", alt: "Estúdio com painéis acústicos e tela exibindo a marca Cristal Studios" },
  { src: "/estudios/estrutura-3.jpg", alt: "Sala de controle com mesa de áudio e monitores de estúdio" },
  { src: "/estudios/estrutura-2.jpg", alt: "Bancada de podcast com microfones profissionais e painel ON AIR" },
  { src: "/estudios/estrutura-6.jpg", alt: "Estação de áudio com mesa de mixagem e iluminação de ambiente" },
  { src: "/estudios/estrutura-5.jpg", alt: "Lounge e área de convivência do estúdio" },
];

// CENÁRIOS — substitua imagens em /public/cenarios/ e ajuste nome/descrição
const cenarios = [
  {
    src: "/cenarios/agata-ambar.jpg",
    nome: "Estúdio Ágata",
    desc: "Parede de pedra natural, painel acústico de madeira e tela com a sua marca. Iluminação personalizável para podcasts e entrevistas com visual sofisticado.",
    alt: "Estúdio Ágata da Cristal Studios em iluminação âmbar",
  },
  {
    src: "/cenarios/agata-azul.jpg",
    nome: "Estúdio Ágata",
    desc: "Iluminação RGB totalmente personalizável — o mesmo set em clima azul tecnológico, adaptando o ambiente a cada projeto.",
    alt: "Estúdio Ágata da Cristal Studios em iluminação azul",
  },
  {
    src: "/cenarios/safira.jpg",
    nome: "Estúdio Safira",
    desc: "Cenário cinematográfico com spots de palco, iluminação RGB e painel ON AIR. Visual de impacto para podcasts e formatos premium.",
    alt: "Estúdio Safira da Cristal Studios",
  },
  {
    src: "/cenarios/safira-detalhe.jpg",
    nome: "Estúdio Safira",
    desc: "Estrutura completa de captação — múltiplas câmeras e luz azul cinematográfica para uma produção de alto nível.",
    alt: "Estúdio Safira da Cristal Studios durante uma gravação",
  },
  {
    src: "/cenarios/perola.jpg",
    nome: "Estúdio Pérola",
    desc: "Lounge sofisticado com poltronas confortáveis e painéis acústicos iluminados. Perfeito para rodas de conversa e formatos mais descontraídos.",
    alt: "Estúdio Pérola da Cristal Studios em iluminação azul",
  },
  {
    src: "/cenarios/perola-detalhe.jpg",
    nome: "Estúdio Pérola",
    desc: "Ambiente acolhedor em clima quente durante a gravação, com estrutura de câmeras pronta para receber seus convidados.",
    alt: "Estúdio Pérola da Cristal Studios em iluminação quente durante gravação",
  },
];

// PRODUÇÕES — adicione os vídeos em /public/producoes/ e preencha o campo `video`
const producoes = [
  {
    nome: "Podcast & Videocast",
    icon: "🎙️",
    tags: ["Episódios completos", "Cortes", "Bastidores", "Clientes"],
    texto: "Conversas que geram autoridade, relacionamento e posicionamento para empresas, especialistas e marcas.",
    video: "", // ex: "/producoes/podcast.mp4"
    poster: "",
  },
  {
    nome: "Vídeo Aulas e Cursos Online",
    icon: "🎓",
    tags: ["Especialistas gravando", "Cursos", "Mentorias"],
    texto: "Produções educacionais com qualidade profissional para treinamentos, mentorias e infoprodutos.",
    video: "",
    poster: "",
  },
  {
    nome: "Treinamentos Corporativos",
    icon: "🏢",
    tags: ["Empresas", "Capacitações", "Integrações"],
    texto: "Conteúdos internos que ajudam empresas a padronizar processos, acelerar treinamentos e desenvolver equipes.",
    video: "",
    poster: "",
  },
  {
    nome: "Conteúdo para Redes Sociais",
    icon: "📱",
    tags: ["Reels", "Shorts", "Vídeos verticais"],
    texto: "Transformamos uma gravação em dezenas de conteúdos para ampliar o alcance da sua marca.",
    video: "",
    poster: "",
  },
  {
    nome: "Conteúdo Institucional",
    icon: "🎬",
    tags: ["Apresentações empresariais", "Cases", "Cultura organizacional"],
    texto: "Vídeos que fortalecem a imagem da empresa e comunicam seus diferenciais de forma clara e profissional.",
    video: "",
    poster: "",
  },
  {
    nome: "Eventos Corporativos",
    icon: "🎤",
    tags: ["Coberturas", "Palestras", "Congressos"],
    texto: "Registros profissionais para preservar e amplificar os momentos mais importantes da sua empresa.",
    video: "",
    poster: "",
  },
];
---

<Layout
  title="Cristal Studios — Podcast, Vídeo e Áudio Profissional em Campinas/SP"
  description="Produtora de podcast, vídeo institucional, jingles e estratégia de conteúdo em Campinas/SP. +40 anos de experiência. Diagnóstico gratuito."
>

  <!-- HERO FULL-BLEED (vídeo/imagem) -->
  <section class="hero-full" id="home">
    <video
      class="hero-bg"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/hero-poster.jpg"
    >
      <source src="/hero.webm" type="video/webm" />
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-vignette"></div>

    <div class="hero-bottom">
      <div class="hero-text">
        <h1 class="hero-headline">
          <span><strong>Quem não é visto,</strong> é comparado.</span>
          <span><strong>Quem é autoridade,</strong> é escolhido.</span>
        </h1>
        <p class="hero-subline">
          Podcast, vídeo e conteúdo estratégico para posicionar sua marca no próximo nível.
        </p>
        <a href={WA_LINK} target="_blank" rel="noopener" class="hero-cta">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Quero agendar uma visita
        </a>
      </div>
      <div class="hero-badges">
        <span class="hero-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M5 12h14"/></svg>
          +40 anos de mercado
        </span>
        <span class="hero-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Produção completa
        </span>
      </div>
    </div>
  </section>

  <!-- ════════ ESTÚDIOS (2ª dobra) ════════ -->
  <section class="section section-dark estudios" id="estudios">

    <!-- ESTRUTURA -->
    <div class="container estrutura-head" id="estrutura">
      <div class="section-tag estrutura-tag">ESTRUTURA</div>
      <h2 class="estrutura-title">
        Estrutura profissional para marcas<br />que valorizam a própria imagem.
      </h2>
      <p class="estrutura-sub">
        Ambientes planejados, equipamentos de alto padrão e mais de 40 anos de
        experiência audiovisual para transformar cada gravação em uma experiência premium.
      </p>
    </div>

    <div class="coverflow" id="coverflow">
      <button class="cf-arrow cf-prev" id="cfPrev" aria-label="Imagem anterior" type="button">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="cf-stage" id="cfStage">
        {estruturaImgs.map((img, i) => (
          <figure class="cf-item" data-index={i}>
            <img src={img.src} alt={img.alt} loading="lazy" />
          </figure>
        ))}
      </div>

      <button class="cf-arrow cf-next" id="cfNext" aria-label="Próxima imagem" type="button">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <div class="cf-dots" id="cfDots" role="tablist" aria-label="Navegação do carrossel"></div>
    </div>

    <!-- CENÁRIOS -->
    <div class="container cenarios" id="cenarios">
      <div class="cenarios-head">
        <div class="section-tag">CENÁRIOS</div>
        <h2>Ambientes pensados para <span class="highlight">valorizar sua marca.</span></h2>
      </div>

      <div class="cenarios-body">
      <div class="vcar" id="vcar">
        <div class="vcar-track" id="vcarTrack">
          {cenarios.map((c, i) => (
            <article class="vcar-card" data-index={i}>
              <img src={c.src} alt={c.alt} loading="lazy" />
              <div class="vcar-overlay">
                <h3>{c.nome}</h3>
                <p>{c.desc}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="vcar-dots" id="vcarDots" role="tablist" aria-label="Navegação dos cenários"></div>
        <div class="vcar-arrows">
          <button class="vcar-arrow" id="vcarPrev" aria-label="Cenário anterior" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
          </button>
          <button class="vcar-arrow" id="vcarNext" aria-label="Próximo cenário" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
      </div>

      <div class="cenarios-text">
        <p>Nem toda mensagem deve ser comunicada da mesma forma.</p>
        <p>Por isso, a Cristal Studios oferece ambientes versáteis para podcasts, videocasts, entrevistas, treinamentos, vídeo aulas, cursos online e conteúdos corporativos.</p>
        <p>Cada cenário foi planejado para proporcionar conforto, qualidade visual e flexibilidade, permitindo que sua marca encontre o ambiente ideal para cada projeto.</p>
        <a href={WA_LINK} target="_blank" rel="noopener" class="btn-primary btn-xl" style="margin-top:1rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="margin-right:0.5rem;vertical-align:-4px">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Conhecer os estúdios
        </a>
      </div>
      </div>

      <div class="formatos-grid">
        <div class="formato-card">
          <span class="formato-icon">🎙️</span>
          <h3>Podcast &amp; Videocast</h3>
          <p>Estrutura profissional para entrevistas, bate-papos, programas corporativos e conteúdos voltados para autoridade e relacionamento.</p>
        </div>
        <div class="formato-card">
          <span class="formato-icon">💼</span>
          <h3>Entrevistas &amp; Conteúdo Institucional</h3>
          <p>Um ambiente elegante e acolhedor para depoimentos, apresentações empresariais, cases de sucesso e comunicação corporativa.</p>
        </div>
        <div class="formato-card">
          <span class="formato-icon">🎓</span>
          <h3>Vídeo Aulas &amp; Treinamentos</h3>
          <p>Espaço preparado para cursos online, mentorias, treinamentos internos, capacitações e conteúdos educacionais com qualidade profissional.</p>
        </div>
      </div>
    </div>

    <!-- INFRAESTRUTURA -->
    <div class="container infra" id="infraestrutura">
      <div class="infra-top">
        <div class="infra-intro">
          <div class="section-tag">INFRAESTRUTURA</div>
          <h2>Tecnologia profissional para <span class="highlight">resultados profissionais.</span></h2>
          <p>Por trás de cada gravação existe uma estrutura cuidadosamente planejada para garantir qualidade, segurança e excelência em cada detalhe.</p>
          <p>A Cristal Studios reúne equipamentos de alto padrão, tratamento acústico, iluminação profissional e sistemas avançados de captação para oferecer uma experiência completa de produção audiovisual.</p>
          <p>Tudo foi pensado para que você possa focar exclusivamente no seu conteúdo enquanto nossa equipe cuida de toda a operação técnica.</p>
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn-primary" style="margin-top:0.5rem">Agendar visita ao estúdio</a>
        </div>
        <ul class="infra-checklist">
          <li>Áudio profissional com máxima clareza e definição</li>
          <li>Captação de vídeo em alta qualidade</li>
          <li>Iluminação profissional para valorizar pessoas e cenários</li>
          <li>Monitoramento em tempo real durante as gravações</li>
          <li>Equipe técnica especializada acompanhando toda a produção</li>
          <li>Ambientes climatizados e preparados para longas gravações</li>
          <li>Estrutura ideal para podcasts, videocasts, treinamentos, cursos online e conteúdos corporativos</li>
          <li>Equipamentos de backup para máxima segurança operacional</li>
        </ul>
      </div>

      <div class="infra-cards">
        <div class="infra-card">
          <span class="infra-icon">🎙️</span>
          <h3>Áudio Profissional</h3>
          <p>Microfones e sistemas de captação que garantem clareza, presença e qualidade sonora em cada gravação.</p>
        </div>
        <div class="infra-card">
          <span class="infra-icon">🎬</span>
          <h3>Vídeo em Alta Qualidade</h3>
          <p>Câmeras profissionais e monitoramento em tempo real para imagens nítidas e com acabamento premium.</p>
        </div>
        <div class="infra-card">
          <span class="infra-icon">💡</span>
          <h3>Iluminação Profissional</h3>
          <p>Projetada para valorizar pessoas, cenários e a identidade visual de cada produção.</p>
        </div>
        <div class="infra-card">
          <span class="infra-icon">🛡️</span>
          <h3>Segurança Operacional</h3>
          <p>Equipamentos redundantes e planos de contingência que garantem mais tranquilidade e confiabilidade durante as gravações.</p>
        </div>
        <div class="infra-card">
          <span class="infra-icon">🎛️</span>
          <h3>Direção Técnica Especializada</h3>
          <p>Uma equipe experiente acompanha cada produção para garantir qualidade, segurança e excelência do início ao fim.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUÇÕES -->
  <section class="section" id="producoes">
    <div class="container">
      <div class="section-tag">PRODUÇÕES</div>
      <h2>Conteúdos que transformam <span class="highlight">conhecimento em autoridade.</span></h2>
      <p class="section-sub">Podcasts, videocasts, treinamentos, cursos online e produções audiovisuais criadas para fortalecer marcas, compartilhar experiências e gerar novas oportunidades de negócio.</p>

      <div class="prod-grid">
        {producoes.map((p) => (
          <article class="prod-card">
            <div class="prod-media">
              {p.video
                ? <video src={p.video} poster={p.poster} muted loop playsinline preload="metadata"></video>
                : <span class="prod-media-icon">{p.icon}</span>}
              {!p.video && <span class="prod-media-badge">Em breve: vídeo</span>}
            </div>
            <div class="prod-body">
              <h3>{p.nome}</h3>
              <div class="prod-tags">
                {p.tags.map((t) => <span class="prod-tag">{t}</span>)}
              </div>
              <p>{p.texto}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="section section-dark" id="como-funciona">
    <div class="container">
      <div class="cf-head">
        <div class="section-tag">COMO FUNCIONA</div>
        <h2>Um processo simples, profissional e pensado para <span class="highlight">você focar apenas no conteúdo.</span></h2>
        <p class="cf-intro">Da preparação à entrega final, nossa equipe cuida de toda a operação para garantir uma experiência tranquila e uma produção com qualidade profissional.</p>
      </div>

      <ol class="steps">
        <li class="step">
          <div class="step-num">1</div>
          <span class="step-label">Etapa 1</span>
          <h3>Planejamento da Produção</h3>
          <p>Antes da gravação, alinhamos todos os detalhes necessários para que a produção aconteça da melhor forma possível. Definimos cenários, iluminação, identidade visual, vinhetas, elementos gráficos e participantes — tudo preparado para que sua marca seja representada com qualidade e consistência.</p>
        </li>
        <li class="step">
          <div class="step-num">2</div>
          <span class="step-label">Etapa 2</span>
          <h3>Gravação</h3>
          <p>Chegou o dia de transformar ideias em conteúdo. Nossa equipe cuida de toda a operação técnica — áudio, vídeo, iluminação, enquadramentos e monitoramento — para que você e seus convidados foquem exclusivamente na conversa, apresentação ou treinamento.</p>
        </li>
        <li class="step">
          <div class="step-num">3</div>
          <span class="step-label">Etapa 3</span>
          <h3>Pós-Produção</h3>
          <p>Após a gravação, iniciamos a edição e finalização: ajustes de áudio, correções de imagem, inserção de vinhetas, elementos gráficos e demais recursos necessários para entregar um conteúdo profissional e alinhado à identidade da sua marca.</p>
        </li>
        <li class="step">
          <div class="step-num">4</div>
          <span class="step-label">Etapa 4</span>
          <h3>Entrega dos Materiais</h3>
          <p>Com tudo finalizado, os conteúdos são organizados e disponibilizados para sua equipe. Dependendo do projeto, a entrega inclui episódios completos, videocasts, vídeo aulas, treinamentos, conteúdos institucionais e cortes para redes sociais — prontos para publicação.</p>
        </li>
      </ol>

      <div class="cf-closing">
        <div class="cf-closing-img">
          <img src="/cenarios/agata-ambar.jpg" alt="Equipe Cristal Studios em produção" />
        </div>
        <div class="cf-closing-text">
          <h3>Você compartilha seu conhecimento.<br /><span class="highlight">Nós cuidamos de todo o resto.</span></h3>
          <p>Nossa missão é tornar o processo de produção simples, eficiente e profissional, para que você tenha a tranquilidade de focar no que realmente importa: sua mensagem.</p>
          <a href={WA_LINK_PODCAST} target="_blank" rel="noopener" class="btn-primary btn-xl" style="margin-top:0.5rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="margin-right:0.5rem;vertical-align:-4px">
