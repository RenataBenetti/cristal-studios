    filter: drop-shadow(0 0 9px rgba(232,130,26,0.5));
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .servico-card:hover .servico-icon,
  .formato-card:hover .formato-icon,
  .infra-card:hover .infra-icon,
  .valor-card:hover .valor-icon {
    filter: drop-shadow(0 0 18px rgba(232,130,26,0.9));
    transform: scale(1.08);
  }

  /* ─── MOBILE ─── */
  @media (max-width: 900px) {
    .estudio-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .estudio-img img { height: 280px; }
    .estudio-detalhe { margin-top: 4rem; }
    .contato-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .cta-card { flex-direction: column; text-align: center; }
    .coverflow { height: 380px; margin-top: 2.5rem; }
    .cf-item { width: min(540px, 84vw); height: 320px; }
    .cf-arrow { width: 42px; height: 42px; }
    .cf-prev { left: 0.5rem; }
    .cf-next { right: 0.5rem; }

    .cenarios { margin-top: 4rem; }
    .cenarios-body { grid-template-columns: 1fr; gap: 2.5rem; }
    .formatos-grid { grid-template-columns: 1fr; margin-top: 3rem; }
    .infra-top { grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 3rem; }
    .steps { grid-template-columns: 1fr 1fr; gap: 2.8rem 1.5rem; }
    .steps::before { display: none; }
    .cf-closing { grid-template-columns: 1fr; }
    .cf-closing-text { padding: 2rem; }
    .cf-closing-img img { min-height: 240px; }
    .cenarios-text { order: 2; }
    .vcar { order: 1; height: 440px; }
    .vcar-card { height: 360px; }
  }
  @media (max-width: 600px) {
    .servicos-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ─── Coverflow carousel (ESTRUTURA) ───
  function initCoverflow() {
    const stage = document.getElementById('cfStage');
    if (!stage) return;
    const items = Array.from(stage.querySelectorAll<HTMLElement>('.cf-item'));
    const dotsWrap = document.getElementById('cfDots');
    const n = items.length;
    if (!n) return;

    let active = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const dots = items.map((_, i) => {
      const b = document.createElement('button');
      b.className = 'cf-dot';
      b.type = 'button';
      b.setAttribute('role', 'tab');
      b.setAttribute('aria-label', `Ir para imagem ${i + 1}`);
      b.addEventListener('click', () => { go(i); reset(); });
      dotsWrap?.appendChild(b);
      return b;
    });

    function render() {
      items.forEach((item, i) => {
        let offset = i - active;
        if (offset > n / 2) offset -= n;
        if (offset < -n / 2) offset += n;
        const abs = Math.abs(offset);

        item.classList.toggle('is-active', offset === 0);
        item.classList.toggle('is-side', offset !== 0);

        if (abs > 2) {
          item.style.opacity = '0';
          item.style.pointerEvents = 'none';
          item.style.transform = `translate(-50%, -50%) translateX(${offset > 0 ? 150 : -150}%) scale(0.6)`;
        } else {
          const tx = offset * 46;
          const rot = offset * -32;
          const scale = abs === 0 ? 1 : abs === 1 ? 0.7 : 0.54;
          const op = abs === 0 ? 1 : abs === 1 ? 0.6 : 0.28;
          item.style.opacity = String(op);
          item.style.pointerEvents = 'auto';
          item.style.transform = `translate(-50%, -50%) translateX(${tx}%) rotateY(${rot}deg) scale(${scale})`;
          item.style.zIndex = String(20 - abs);
        }
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === active));
    }

    function go(i: number) { active = (i + n) % n; render(); }
    function next() { go(active + 1); }
    function prev() { go(active - 1); }

    function reset() {
      if (timer) clearInterval(timer);
      timer = setInterval(next, 4500);
    }

    document.getElementById('cfNext')?.addEventListener('click', () => { next(); reset(); });
    document.getElementById('cfPrev')?.addEventListener('click', () => { prev(); reset(); });
    items.forEach((item, i) => item.addEventListener('click', () => { if (i !== active) { go(i); reset(); } }));

    const cf = document.getElementById('coverflow');
    cf?.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
    cf?.addEventListener('mouseleave', reset);

    render();
    reset();
  }

  initCoverflow();

  // ─── Carrossel vertical (CENÁRIOS) ───
  function initVCar() {
    const track = document.getElementById('vcarTrack');
    const vcar = document.getElementById('vcar');
    const dotsWrap = document.getElementById('vcarDots');
    if (!track || !vcar) return;
    const cards = Array.from(track.querySelectorAll<HTMLElement>('.vcar-card'));
    const n = cards.length;
    if (!n) return;

    let active = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const dots = cards.map((_, i) => {
      const b = document.createElement('button');
      b.className = 'vcar-dot';
      b.type = 'button';
      b.setAttribute('role', 'tab');
      b.setAttribute('aria-label', `Ir para cenário ${i + 1}`);
      b.addEventListener('click', () => { go(i); reset(); });
      dotsWrap?.appendChild(b);
      return b;
    });

    function render() {
      const card = cards[0];
      const styles = getComputedStyle(track as HTMLElement);
      const gap = parseFloat(styles.rowGap || styles.gap || '0') || 0;
      const step = card.offsetHeight + gap;
      (track as HTMLElement).style.transform = `translateY(${-active * step}px)`;
      cards.forEach((c, i) => c.style.opacity = i === active ? '1' : '0.5');
      dots.forEach((d, i) => d.classList.toggle('active', i === active));
    }

    function go(i: number) { active = (i + n) % n; render(); }
    function next() { go(active + 1); }

    function reset() {
      if (timer) clearInterval(timer);
      timer = setInterval(next, 4000);
    }

    cards.forEach((c, i) => c.addEventListener('click', () => { if (i !== active) { go(i); reset(); } }));
    vcar.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
    vcar.addEventListener('mouseleave', reset);

    document.getElementById('vcarPrev')?.addEventListener('click', () => { go(active - 1); reset(); });
    document.getElementById('vcarNext')?.addEventListener('click', () => { go(active + 1); reset(); });
    window.addEventListener('resize', render);

    render();
    reset();
  }

  initVCar();

  // ── DEPOIMENTOS CARROSSEL 3-SLOTS ─────────────────────────────
  (function initDepoCarousel() {
    const DATA = [
      { src: '/depoimentos/fabio.mp4',  name: 'Fábio',   role: 'Empresário · Campinas/SP' },
      { src: '/depoimentos/george.mp4', name: 'George',  role: 'Cliente · Campinas/SP' },
      { src: '/depoimentos/desire.mp4', name: 'Desirée', role: 'Cliente · Campinas/SP' },
      { src: '/depoimentos/olga.mp4',   name: 'Olga',    role: 'Empreendedora · Campinas/SP' },
    ];
    const N = DATA.length;
    const slotPrev   = document.getElementById('depoSlotPrev');
    const slotCenter = document.getElementById('depoSlotCenter');
    const slotNext   = document.getElementById('depoSlotNext');
    const dots       = Array.from(document.querySelectorAll('.depo-dot'));
    if (!slotCenter) return;

    let current = 0;

    function idx(offset) { return (current + offset + N) % N; }

    function fillSlot(slot, dataIdx) {
      const v   = slot.querySelector('video');
      const cap = slot.querySelector('.depo-caption');
      const d   = DATA[dataIdx];
      if (v.src !== location.origin + d.src) {
        v.pause();
        v.src = d.src;
        v.load();
      }
      cap.querySelector('strong').textContent = d.name;
      cap.querySelector('span').textContent   = d.role;
    }

    function render() {
      fillSlot(slotPrev,   idx(-1));
      fillSlot(slotCenter, idx(0));
      fillSlot(slotNext,   idx(1));

      dots.forEach((d, i) => d.classList.toggle('active', i === current));

      // play center, pause sides
      const cv = slotCenter.querySelector('video');
      // pause todos; usuário clica para tocar com som
      cv.pause();
      cv.muted = false;
      slotPrev.querySelector('video').pause();
      slotNext.querySelector('video').pause();

      // sempre mostrar o botão de play ao trocar de vídeo
      const btn = slotCenter.querySelector('.depo-play-btn');
      if (btn) btn.classList.remove('hidden');
    }

    function goTo(n) {
      current = (n + N) % N;
      render();
    }

    document.getElementById('depoPrev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('depoNext')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.idx)));

    // side slot click → move to that video
    slotPrev.addEventListener('click', () => goTo(current - 1));
    slotNext.addEventListener('click', () => goTo(current + 1));

    // play/pause center video on button click
    const playBtn = slotCenter.querySelector('.depo-play-btn');
    if (playBtn) {
      playBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const v = slotCenter.querySelector('video');
        if (v.paused) { v.muted = false; v.play().catch(() => { v.muted = true; v.play(); }); }
        else v.pause();
      });
      slotCenter.querySelector('video').addEventListener('play',  () => playBtn.classList.add('hidden'));
      slotCenter.querySelector('video').addEventListener('pause', () => playBtn.classList.remove('hidden'));
    }

    render();
  })();
</script>
