  /* ─── HERO LEGACY (split layout — sem uso na home atual mas mantido pra outras pages) ─── */
  .hero {
    display: grid; grid-template-columns: 1fr 1fr;
    min-height: 91vh; align-items: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; top: -20%; left: -10%;
