---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogJsonLd from '../../components/BlogJsonLd.astro';
import { CATEGORIES, formatDate } from '../../lib/blog';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const rest = allPosts.filter(p => p.id !== featured?.id);

const categories = Object.values(CATEGORIES);

const blogTitle = "Blog Cristal Studios — Estratégia, Podcast, Vídeo e Conteúdo";
const blogDescription = "Insights estratégicos de quem produz podcast, vídeo e áudio profissional há mais de 40 anos. Conteúdo prático para empresas que querem construir autoridade real.";
---

<Layout title={blogTitle} description={blogDescription}>
  <BlogJsonLd
    type="blog"
    title={blogTitle}
    description={blogDescription}
    url="/blog"
  />
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <span class="blog-tag">BLOG</span>
      <h1>Estratégia, bastidores e o que aprendemos<br /><span class="highlight">em 40 anos produzindo conteúdo.</span></h1>
      <p>Textos práticos para empresas que querem parar de fazer conteúdo e começar a construir autoridade.</p>
    </div>
  </section>

  <section class="blog-filters">
    <div class="blog-filters-inner">
      <a href="/blog" class="filter-chip active">Todos</a>
      {categories.map(cat => (
        <a href={`/blog/categoria/${cat.slug}`} class="filter-chip">{cat.name}</a>
      ))}
    </div>
  </section>

  {featured && (
    <section class="featured-section">
      <div class="featured-inner">
        <a href={`/blog/${featured.id}`} class="featured-card">
          {featured.data.coverImage ? (
            <div class="featured-img">
              <img src={featured.data.coverImage} alt={featured.data.coverAlt ?? featured.data.title} />
            </div>
          ) : (
            <div class="featured-img featured-img-placeholder">
              <span>{CATEGORIES[featured.data.category].shortName}</span>
            </div>
          )}
          <div class="featured-body">
            <span class="featured-pill">Em destaque · {CATEGORIES[featured.data.category].name}</span>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.excerpt}</p>
            <div class="featured-meta">
              <span>{featured.data.author}</span>
              <span class="dot">·</span>
              <time datetime={featured.data.publishedAt.toISOString()}>{formatDate(featured.data.publishedAt)}</time>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="posts-section">
      <div class="posts-inner">
        <h2 class="section-heading">Últimos artigos</h2>
        <div class="posts-grid">
          {rest.map(post => (
            <a href={`/blog/${post.id}`} class="post-card">
              {post.data.coverImage ? (
                <div class="post-card-img">
                  <img src={post.data.coverImage} alt={post.data.coverAlt ?? post.data.title} />
                </div>
              ) : (
                <div class="post-card-img post-card-img-placeholder">
                  <span>{CATEGORIES[post.data.category].shortName}</span>
                </div>
              )}
              <div class="post-card-body">
                <span class="post-card-category">{CATEGORIES[post.data.category].name}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt}</p>
                <time class="post-card-date" datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {allPosts.length === 0 && (
    <section class="empty-state">
      <p>Em breve, conteúdo novo aqui. Volte logo.</p>
    </section>
  )}
</Layout>

<style>
  .blog-hero {
    padding: 9rem 2rem 3rem;
    text-align: center;
    background:
      radial-gradient(ellipse at top, rgba(232,130,26,0.12) 0%, transparent 60%),
      var(--black);
  }
  .blog-hero-inner {
    max-width: 880px;
    margin: 0 auto;
  }
  .blog-tag {
    display: inline-block;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--amber);
    background: rgba(232,130,26,0.1);
    border: 1px solid rgba(232,130,26,0.35);
    padding: 0.45rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .blog-hero h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1.2rem;
  }
  .highlight { color: var(--amber); }
  .blog-hero p {
    font-size: 1.1rem;
    color: #aaa;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto;
  }

  .blog-filters {
    padding: 0 2rem 2.5rem;
  }
  .blog-filters-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 0.5rem;
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: #ccc;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .filter-chip:hover {
    border-color: var(--amber);
    color: var(--amber);
  }
  .filter-chip.active {
    background: var(--amber);
    color: #000;
    border-color: var(--amber);
  }

  .featured-section {
    padding: 2rem 2rem 4rem;
  }
  .featured-inner {
    max-width: 1140px;
    margin: 0 auto;
  }
  .featured-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, transform 0.2s, box-shadow 0.25s;
  }
  .featured-card:hover {
    border-color: var(--amber);
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.4), 0 0 50px rgba(232,130,26,0.15);
  }
  .featured-img {
    background: var(--dark);
    min-height: 360px;
    position: relative;
    overflow: hidden;
  }
  .featured-img img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  .featured-img-placeholder {
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(ellipse at center, rgba(232,130,26,0.25) 0%, transparent 65%),
      linear-gradient(135deg, var(--card) 0%, var(--dark) 100%);
  }
  .featured-img-placeholder span {
    font-size: 4rem;
    font-weight: 900;
    color: rgba(232,130,26,0.6);
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .featured-body {
    padding: 3rem;
    display: flex; flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .featured-pill {
    display: inline-block;
    width: fit-content;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--amber);
    background: rgba(232,130,26,0.1);
    border: 1px solid rgba(232,130,26,0.3);
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
  }
  .featured-body h2 {
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .featured-body p {
    color: #aaa;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }
  .featured-meta {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem;
    color: #777;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .featured-meta .dot { color: #555; }

  .posts-section {
    padding: 0 2rem 6rem;
  }
  .posts-inner {
    max-width: 1140px;
    margin: 0 auto;
  }
  .section-heading {
    font-size: 1.3rem;
    font-weight: 700;
    color: #aaa;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex; flex-direction: column;
    transition: border-color 0.25s, transform 0.2s;
  }
  .post-card:hover {
    border-color: var(--amber);
    transform: translateY(-3px);
  }
  .post-card-img {
    aspect-ratio: 16 / 9;
    background: var(--dark);
    overflow: hidden;
  }
  .post-card-img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .post-card-img-placeholder {
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(ellipse at center, rgba(232,130,26,0.2) 0%, transparent 65%),
      linear-gradient(135deg, var(--card) 0%, var(--dark) 100%);
  }
  .post-card-img-placeholder span {
    font-size: 2rem; font-weight: 900;
    color: rgba(232,130,26,0.55);
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .post-card-body {
    padding: 1.5rem;
    display: flex; flex-direction: column; gap: 0.7rem;
    flex: 1;
  }
  .post-card-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .post-card-body h3 {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .post-card-body p {
    color: #999;
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .post-card-date {
    color: #666;
    font-size: 0.8rem;
    margin-top: 0.3rem;
  }

  .empty-state {
    padding: 4rem 2rem 8rem;
    text-align: center;
  }
  .empty-state p {
    color: #888;
    font-size: 1.05rem;
  }

  @media (max-width: 900px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-img { min-height: 240px; }
    .featured-body { padding: 2rem 1.5rem; }
  }
  @media (max-width: 600px) {
    .blog-hero { padding: 7rem 1.2rem 2rem; }
    .blog-filters { padding: 0 1.2rem 2rem; }
    .featured-section, .posts-section { padding-left: 1.2rem; padding-right: 1.2rem; }
  }
</style>
