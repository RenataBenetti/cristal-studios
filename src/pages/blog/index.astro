---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogJsonLd from '../../components/BlogJsonLd.astro';
import { CATEGORIES, formatDate } from '../../lib/blog';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const blogTitle = "Blog Cristal Studios: Estratégia, Podcast, Vídeo e Conteúdo";
const blogDescription = "Insights estratégicos de quem produz podcast, vídeo e áudio profissional há mais de 40 anos. Conteúdo prático para empresas que querem construir autoridade real.";
---

<Layout title={blogTitle} description={blogDescription}>
  <BlogJsonLd
    type="blog"
    title={blogTitle}
    description={blogDescription}
    url="/blog"
  />
  <section class="blog">
    <div class="blog-inner">
      <header class="blog-head">
        <p class="eyebrow">BLOG</p>
        <h1>Estratégia, bastidores e o que aprendemos em 40 anos produzindo conteúdo.</h1>
        <p class="blog-sub">Textos práticos para empresas que querem parar de fazer conteúdo e começar a construir autoridade.</p>
      </header>

      {allPosts.length > 0 ? (
        <div class="posts-grid">
          {allPosts.map(post => (
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="post-img">
                {post.data.coverImage ? (
                  <img src={post.data.coverImage} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
                ) : (
                  <div class="post-img-placeholder">
                    <span>{CATEGORIES[post.data.category].shortName}</span>
                  </div>
                )}
                <span class="post-tag">#{CATEGORIES[post.data.category].shortName.toUpperCase()}</span>
              </div>
              <div class="post-body">
                <h2>{post.data.title}</h2>
                <p class="post-excerpt">{post.data.excerpt}</p>
                <div class="post-foot">
                  <span class="read-more">
                    <span class="arrow-box">
                      <svg class="arrow arrow-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      <svg class="arrow arrow-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                    Leia mais
                  </span>
                  <span class="post-date">
                    <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
                    <span class="date-line"></span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Em breve, conteúdo novo aqui. Volte logo.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog {
    background: var(--black);
    padding: 9rem 1.5rem 6rem;
  }
  .blog-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 4rem;
  }
  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .blog-head h1 {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0 0 1.2rem;
  }
  .blog-sub {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #aaa;
    max-width: 600px;
    margin: 0 auto;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    background: var(--card);
    transition: border-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }
  .post-card:hover {
    border-color: var(--amber);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.45), 0 0 40px rgba(232,130,26,0.12);
  }

  .post-img {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--dark);
  }
  .post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at center, rgba(232,130,26,0.22) 0%, transparent 65%),
      linear-gradient(135deg, var(--card) 0%, var(--dark) 100%);
  }
  .post-img-placeholder span {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: rgba(232,130,26,0.55);
    text-transform: uppercase;
  }
  .post-tag {
    position: absolute;
    top: 0;
    left: 0;
    background: rgba(10,10,10,0.85);
    color: #f0f0f0;
    border: 1px solid rgba(255,255,255,0.12);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 0.45rem 0.85rem;
    backdrop-filter: blur(4px);
  }

  .post-body {
    padding: 1.5rem 1.4rem 1.6rem;
  }
  .post-body h2 {
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--white);
    margin: 0 0 0.75rem;
  }
  .post-excerpt {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #999;
    margin: 0 0 1.5rem;
  }

  .post-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .read-more {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: #f0f0f0;
  }
  .arrow-box {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    margin-right: 0.7rem;
    border: 1px solid var(--border);
    overflow: hidden;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .arrow {
    position: absolute;
    width: 1rem;
    height: 1rem;
  }
  .arrow-1 {
    transform: translateX(0);
    opacity: 1;
    transition: transform 0.5s ease-in, opacity 0.5s ease-in;
  }
  .arrow-2 {
    left: -1.4rem;
    transform: translateY(0);
    transition: left 0.5s ease-in-out;
  }
  .post-card:hover .arrow-box {
    background: var(--amber);
    border-color: var(--amber);
    color: #000000;
  }
  .post-card:hover .arrow-1 {
    transform: translateX(2rem);
    opacity: 0;
  }
  .post-card:hover .arrow-2 {
    left: 0.7rem;
  }

  .post-date {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: #777;
    white-space: nowrap;
  }
  .date-line {
    display: inline-block;
    width: 3.5rem;
    height: 1px;
    background: var(--border);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
  }
  .empty-state p {
    color: #888;
    font-size: 1.05rem;
  }

  @media (max-width: 600px) {
    .blog { padding: 7rem 1.2rem 4rem; }
    .blog-head { margin-bottom: 2.5rem; }
    .post-date .date-line { width: 2rem; }
  }
</style>
