---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogJsonLd from '../../../components/BlogJsonLd.astro';
import { CATEGORIES, formatDate, getPostSlug, isPublished, isCategorySlug, type CategorySlug } from '../../../lib/blog';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map(slug => ({
    params: { categoria: slug },
    props: { categorySlug: slug as CategorySlug },
  }));
}

const { categorySlug } = Astro.props;

if (!isCategorySlug(categorySlug)) {
  throw new Error(`Categoria desconhecida: ${categorySlug}`);
}

const category = CATEGORIES[categorySlug];

const posts = (await getCollection('blog', ({ data }) => isPublished(data) && data.category === categorySlug))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const allCategories = Object.values(CATEGORIES);

const pageTitle = `${category.name}: Blog Cristal Studios`;
const pageDescription = category.description;
---

<Layout title={pageTitle} description={pageDescription}>
  <BlogJsonLd
    type="category"
    title={pageTitle}
    description={pageDescription}
    url={`/blog/categoria/${categorySlug}`}
    category={categorySlug}
  />
  <section class="cat-hero">
    <div class="cat-hero-inner">
      <a href="/blog" class="back-chip">← Blog</a>
      <span class="cat-tag">CATEGORIA</span>
      <h1>{category.name}</h1>
      <p>{category.description}</p>
    </div>
  </section>

  <section class="blog-filters">
    <div class="blog-filters-inner">
      <a href="/blog" class="filter-chip">Todos</a>
      {allCategories.map(cat => (
        <a
          href={`/blog/categoria/${cat.slug}`}
          class:list={['filter-chip', { active: cat.slug === categorySlug }]}
        >
          {cat.name}
        </a>
      ))}
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-inner">
      {posts.length === 0 ? (
        <p class="empty">Em breve, conteúdo nesta categoria.</p>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/blog/${getPostSlug(post)}`} class="post-card">
              {post.data.coverImage ? (
                <div class="post-card-img">
                  <img src={post.data.coverImage} alt={post.data.coverAlt ?? post.data.title} />
                </div>
              ) : (
                <div class="post-card-img post-card-img-placeholder">
                  <span>{category.shortName}</span>
                </div>
              )}
              <div class="post-card-body">
                <span class="post-card-category">{category.name}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt}</p>
                <time class="post-card-date" datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .cat-hero {
    padding: 8.5rem 2rem 2.5rem;
    text-align: center;
    background:
      radial-gradient(ellipse at top, rgba(232,130,26,0.12) 0%, transparent 60%),
      var(--black);
  }
  .cat-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .back-chip {
    display: inline-block;
    color: #888;
    font-size: 0.85rem;
    text-decoration: none;
    margin-bottom: 1.2rem;
    transition: color 0.2s;
  }
  .back-chip:hover { color: var(--amber); }
  .cat-tag {
    display: inline-block;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--amber);
    background: rgba(232,130,26,0.1);
    border: 1px solid rgba(232,130,26,0.35);
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.2rem;
  }
  .cat-hero h1 {
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .cat-hero p {
    font-size: 1.05rem;
    color: #aaa;
    line-height: 1.6;
  }

  .blog-filters {
    padding: 0 2rem 2.5rem;
  }
  .blog-filters-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 0.5rem;
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: #ccc;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .filter-chip:hover {
    border-color: var(--amber);
    color: var(--amber);
  }
  .filter-chip.active {
    background: var(--amber);
    color: #000;
    border-color: var(--amber);
  }

  .posts-section { padding: 0 2rem 6rem; }
  .posts-inner { max-width: 1140px; margin: 0 auto; }
  .empty {
    text-align: center;
    color: #888;
    padding: 4rem 0;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex; flex-direction: column;
    transition: border-color 0.25s, transform 0.2s;
  }
  .post-card:hover {
    border-color: var(--amber);
    transform: translateY(-3px);
  }
  .post-card-img {
    aspect-ratio: 16 / 9;
    background: var(--dark);
    overflow: hidden;
  }
  .post-card-img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .post-card-img-placeholder {
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(ellipse at center, rgba(232,130,26,0.2) 0%, transparent 65%),
      linear-gradient(135deg, var(--card) 0%, var(--dark) 100%);
  }
  .post-card-img-placeholder span {
    font-size: 2rem; font-weight: 900;
    color: rgba(232,130,26,0.55);
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .post-card-body {
    padding: 1.5rem;
    display: flex; flex-direction: column; gap: 0.7rem;
    flex: 1;
  }
  .post-card-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .post-card-body h3 {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .post-card-body p {
    color: #999;
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .post-card-date {
    color: #666;
    font-size: 0.8rem;
    margin-top: 0.3rem;
  }

  @media (max-width: 600px) {
    .cat-hero { padding: 7rem 1.2rem 2rem; }
    .blog-filters { padding: 0 1.2rem 2rem; }
    .posts-section { padding-left: 1.2rem; padding-right: 1.2rem; }
  }
</style>
