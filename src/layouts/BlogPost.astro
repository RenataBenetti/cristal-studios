---
import Layout from './Layout.astro';
import BlogJsonLd from '../components/BlogJsonLd.astro';
import { CATEGORIES, formatDate, type CategorySlug } from '../lib/blog';

export interface Props {
  slug: string;
  title: string;
  excerpt: string;
  category: CategorySlug;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  coverImage?: string;
  coverAlt?: string;
  readingTime?: number;
  wordCount?: number;
  tags?: string[];
  seo?: { title?: string; description?: string };
}

const {
  slug,
  title,
  excerpt,
  category,
  publishedAt,
  updatedAt,
  author,
  coverImage,
  coverAlt,
  readingTime,
  wordCount,
  tags = [],
  seo,
} = Astro.props;
const cat = CATEGORIES[category];
const url = `/blog/${slug}`;
---

<Layout
  title={seo?.title ?? `${title} — Cristal Studios`}
  description={seo?.description ?? excerpt}
  image={coverImage}
  ogType="article"
  article={{
    publishedTime: publishedAt,
    modifiedTime: updatedAt,
    author,
    section: cat.name,
    tags,
  }}
>
  <BlogJsonLd
    type="post"
    title={title}
    description={seo?.description ?? excerpt}
    url={url}
    category={category}
    publishedAt={publishedAt}
    updatedAt={updatedAt}
    author={author}
    coverImage={coverImage}
    readingTime={readingTime}
    wordCount={wordCount}
    tags={tags}
  />
  <article class="post">
    <header class="post-header">
      <div class="post-header-inner">
        <a href={`/blog/categoria/${cat.slug}`} class="post-category">{cat.name}</a>
        <h1>{title}</h1>
        <p class="post-excerpt">{excerpt}</p>
        <div class="post-meta">
          <span>{author}</span>
          <span class="dot">·</span>
          <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
          {readingTime && (
            <>
              <span class="dot">·</span>
              <span>{readingTime} min de leitura</span>
            </>
          )}
        </div>
        {updatedAt && (
          <p class="post-updated">Atualizado em {formatDate(updatedAt)}</p>
        )}
      </div>
    </header>

    {coverImage && (
      <figure class="post-cover">
        <img src={coverImage} alt={coverAlt ?? title} loading="eager" />
      </figure>
    )}

    <div class="post-body container-narrow">
      <slot />
    </div>

    <footer class="post-footer container-narrow">
      <div class="post-cta">
        <h3>Pronto para construir autoridade real?</h3>
        <p>Venha conhecer o estúdio. Sem compromisso. Você sai com um plano claro.</p>
        <a href="/#contato" class="post-cta-btn">Agende sua visita →</a>
      </div>
      <a href="/blog" class="post-back">← Todos os artigos</a>
    </footer>
  </article>
</Layout>

<style>
  .post {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }
  .post-header {
    padding: 0 2rem 3rem;
  }
  .post-header-inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: left;
  }
  .post-category {
    display: inline-block;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--amber);
    background: rgba(232, 130, 26, 0.1);
    border: 1px solid rgba(232, 130, 26, 0.35);
    padding: 0.4rem 0.9rem; border-radius: 100px;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: background 0.2s;
  }
  .post-category:hover {
    background: rgba(232, 130, 26, 0.18);
  }
  .post-header h1 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1.2rem;
  }
  .post-excerpt {
    font-size: 1.2rem;
    line-height: 1.6;
    color: #bbb;
    margin: 0 0 1.5rem;
  }
  .post-meta {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem;
    font-size: 0.85rem;
    color: #888;
  }
  .post-meta .dot { color: #555; }
  .post-updated {
    font-size: 0.8rem;
    color: #666;
    margin-top: 0.5rem;
  }

  .post-cover {
    max-width: 1140px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
  }
  .post-cover img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }

  .container-narrow {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .post-body :global(h2) {
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 3rem 0 1rem;
    color: #fff;
  }
  .post-body :global(h3) {
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 2.2rem 0 0.8rem;
    color: #fff;
  }
  .post-body :global(p) {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #d4d4d4;
    margin: 0 0 1.3rem;
  }
  .post-body :global(strong) { color: #fff; font-weight: 700; }
  .post-body :global(em) { color: #ccc; }
  .post-body :global(a) {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s;
  }
  .post-body :global(a:hover) { color: var(--amber-light); }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
    color: #d4d4d4;
  }
  .post-body :global(li) {
    line-height: 1.7;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }
  .post-body :global(li::marker) { color: var(--amber); }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    font-size: 1.15rem;
    color: #e0e0e0;
  }
  .post-body :global(blockquote p) { font-size: inherit; }
  .post-body :global(code) {
    background: rgba(232, 130, 26, 0.12);
    color: var(--amber);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .post-body :global(pre) {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .post-body :global(pre code) {
    background: none;
    color: #ddd;
    padding: 0;
  }
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    font-size: 0.92rem;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.7rem 1rem;
    text-align: left;
  }
  .post-body :global(th) {
    background: rgba(232, 130, 26, 0.08);
    color: var(--amber);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-body :global(hr) {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2.5rem 0;
  }
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 1.5rem 0;
  }

  .post-footer {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  .post-cta {
    background: linear-gradient(135deg, rgba(232,130,26,0.12) 0%, rgba(232,130,26,0.04) 100%);
    border: 1px solid rgba(232,130,26,0.3);
    border-radius: 16px;
    padding: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }
  .post-cta h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.6rem;
  }
  .post-cta p {
    color: #aaa;
    font-size: 1rem;
    margin: 0 0 1.5rem;
  }
  .post-cta-btn {
    display: inline-block;
    background: var(--amber);
    color: #000;
    font-weight: 700;
    padding: 0.9rem 1.8rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(232,130,26,0.25);
  }
  .post-cta-btn:hover {
    background: var(--amber-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(232,130,26,0.4);
  }
  .post-back {
    display: inline-block;
    color: #888;
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s;
  }
  .post-back:hover { color: var(--amber); }

  @media (max-width: 600px) {
    .post { padding-top: 6.5rem; }
    .post-header { padding: 0 1.2rem 2rem; }
    .post-cover { padding: 0 1.2rem; }
    .container-narrow { padding: 0 1.2rem; }
    .post-cta { padding: 2rem 1.2rem; }
  }
</style>
