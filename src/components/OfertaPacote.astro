---
// Bloco de "pacote/oferta" reutilizável (estilo próprio, funciona em qualquer LP).
interface Props {
  nome: string;
  itens: string[];
  bonus?: string;
  garantia?: string;
}
const { nome, itens, bonus, garantia } = Astro.props;
---
<section class="op-sec">
  <div class="op-wrap">
    <span class="op-eyebrow">Pacote {nome}</span>
    <h2 class="op-title">Tudo o que está <span class="op-am">incluído</span></h2>
    <ul class="op-list">
      {itens.map((i) => (
        <li><span class="op-check">✓</span>{i}</li>
      ))}
      {bonus && (
        <li class="op-bonus"><span class="op-check op-star">★</span><strong>Bônus:</strong> {bonus}</li>
      )}
    </ul>
    {garantia && <p class="op-garantia">{garantia}</p>}
  </div>
</section>

<style>
  .op-sec { padding: 4rem 1.5rem; }
  .op-wrap { max-width: 720px; margin: 0 auto; }
  .op-eyebrow {
    display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--amber); margin-bottom: 1rem;
  }
  .op-title { font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; line-height: 1.25; color: #fff; margin-bottom: 1.75rem; }
  .op-am { color: var(--amber); }
  .op-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  .op-list li { display: flex; align-items: flex-start; gap: 0.85rem; color: #ddd; font-size: 1rem; line-height: 1.5; }
  .op-check {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%;
    background: rgba(232,130,26,0.15); color: var(--amber);
    display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem;
  }
  .op-bonus { color: #fff; }
  .op-star { background: var(--amber); color: #000; }
  .op-garantia { margin-top: 1.75rem; color: #aaa; line-height: 1.8; font-size: 1.02rem; }
</style>
