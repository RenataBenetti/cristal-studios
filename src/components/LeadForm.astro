---
// Formulário de captação reutilizável (estilo próprio, funciona em qualquer página).
// Captura nome, empresa e e-mail, salva na planilha (origem = serviço) e abre o WhatsApp.
import { LEADS_SHEET_URL } from '../lib/leads';

interface Props {
  servico: string;
  titulo?: string;
  texto?: string;
}
const {
  servico,
  titulo = 'Vamos conversar sobre o seu projeto?',
  texto = 'Preencha seus dados e continue a conversa com a gente no WhatsApp.',
} = Astro.props;

const WA_NUMBER = '5519974062004';
const WA_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---
<section class="lf-sec" id="form">
  <div class="lf-wrap">
    <h2 class="lf-title">{titulo}</h2>
    <p class="lf-text">{texto}</p>
    <form id="lead-form" class="lf-form">
      <input type="text" name="nome" required placeholder="Seu nome" autocomplete="name" />
      <input type="text" name="empresa" required placeholder="Nome da empresa" autocomplete="organization" />
      <input type="email" name="email" required placeholder="Seu melhor e-mail" autocomplete="email" />
      <button type="submit" class="lf-btn">
        <Fragment set:html={WA_ICON} />
        Continuar no WhatsApp →
      </button>
    </form>
    <p class="lf-note">Seus dados são usados só para este contato.</p>
  </div>
</section>

<script is:inline define:vars={{ sheetUrl: LEADS_SHEET_URL, waNumber: WA_NUMBER, servico }}>
  (function () {
    var form = document.getElementById('lead-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var nome = (form.nome.value || '').trim();
      var empresa = (form.empresa.value || '').trim();
      var email = (form.email.value || '').trim();
      try {
        fetch(sheetUrl, {
          method: 'POST', mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify({ nome: nome, empresa: empresa, email: email, origem: servico })
        });
      } catch (err) {}
      var msg = 'Olá! Sou ' + nome + ', da ' + empresa + ' (' + email + '). ' +
        'Vim pela página de ' + servico + ' e quero falar com a Cristal Studios.';
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'lead_lp', servico: servico });
      window.open('https://wa.me/' + waNumber + '?text=' + encodeURIComponent(msg), '_blank', 'noopener');
    });
  })();
</script>

<style>
  .lf-sec { padding: 4rem 1.5rem; background: var(--dark); }
  .lf-wrap { max-width: 480px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .lf-title { font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; line-height: 1.25; color: #fff; }
  .lf-text { color: #aaa; }
  .lf-form { display: flex; flex-direction: column; gap: 0.8rem; width: 100%; }
  .lf-form input {
    width: 100%; padding: 0.95rem 1.1rem; font-size: 1rem; font-family: inherit;
    background: rgba(255,255,255,0.05); color: #fff;
    border: 1px solid var(--border); border-radius: 12px;
  }
  .lf-form input::placeholder { color: #888; }
  .lf-form input:focus { outline: none; border-color: var(--amber); }
  .lf-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
    width: 100%; background: var(--amber); color: #000; font-weight: 700;
    font-size: 1.05rem; padding: 1rem 2rem; border-radius: 10px; border: none;
    cursor: pointer; font-family: inherit; transition: background 0.2s, transform 0.15s;
  }
  .lf-btn:hover { background: var(--amber-light); transform: translateY(-2px); }
  .lf-note { font-size: 0.8rem; color: var(--text-muted); }
</style>
